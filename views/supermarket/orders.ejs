<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestão de Encomendas - Marketplace</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <link rel="stylesheet" href="/style/admin.css">
    <link rel="stylesheet" href="/style/supermarket.css">
</head>
<body class="bg-light">

    <%- include('../partials/sidebar-supermarket', { activePage: 'orders' }) %>

    <main class="main-wrapper p-4">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h3 class="fw-bold text-dark mb-1">Gestão de Encomendas</h3>
                <p class="text-secondary small mb-0">Acompanha e atualiza o estado das encomendas da tua loja.</p>
            </div>
        </div>

        <div class="card border-0 shadow-sm" style="border-radius: 12px; overflow: hidden;">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">

                        <thead class="table-light text-secondary">
                            <tr style="font-size: 0.85rem; letter-spacing: 0.5px;">
                                <th class="ps-4 py-3 border-bottom-0 fw-semibold">ID</th>
                                <th class="py-3 border-bottom-0 fw-semibold">CLIENTE</th>
                                <th class="py-3 border-bottom-0 fw-semibold" style="min-width: 200px;">PRODUTOS</th>
                                <th class="py-3 border-bottom-0 fw-semibold">TOTAL</th>
                                <th class="py-3 border-bottom-0 fw-semibold">MÉTODO</th>
                                <th class="py-3 border-bottom-0 fw-semibold">DATA</th>
                                <th class="py-3 border-bottom-0 fw-semibold">ESTADO</th>
                                <th class="text-end pe-4 py-3 border-bottom-0 fw-semibold">AÇÕES</th>
                            </tr>
                        </thead>

                        <tbody>
                            <% if (typeof orders !== 'undefined' && orders.length > 0) { %>
                                <% orders.forEach(order => { %>
                                <tr>
                                    <td class="ps-4">
                                        <span class="text-muted fw-bold" style="font-size:11px;"><%= order._id %></span>
                                    </td>

                                    <td>
                                        <strong><%= order.customer ? order.customer.name : 'N/A' %></strong>
                                    </td>

                                    <td>
                                        <ul class="list-unstyled mb-0 text-muted" style="font-size: 13px;">
                                            <% order.products.forEach(item => { %>
                                                <li><span class="fw-bold text-dark"><%= item.quantity %>x</span> <%= item.product ? item.product.name : 'Produto Indisponível' %></li>
                                            <% }) %>
                                        </ul>
                                    </td>

                                    <td>
                                        <strong class="text-dark"><%= (order.total + order.deliveryCost).toFixed(2) %> €</strong>
                                        <br>
                                        <small class="text-muted" style="font-size: 11px;">Entrega: <%= order.deliveryCost.toFixed(2) %> €</small>
                                    </td>

                                    <td>
                                        <% if (order.deliveryMethod === 'pickup') { %>
                                            <span class="badge bg-light text-dark border"><i class="bi bi-shop me-1"></i> Levantamento</span>
                                        <% } else { %>
                                            <span class="badge bg-light text-dark border"><i class="bi bi-bicycle me-1"></i> Estafeta</span>
                                        <% } %>
                                    </td>

                                    <td class="text-muted" style="font-size: 13px;">
                                        <%= new Date(order.createdAt).toLocaleDateString('pt-PT') %><br>
                                        <%= new Date(order.createdAt).toLocaleTimeString('pt-PT', {hour: '2-digit', minute:'2-digit'}) %>
                                    </td>

                                    <td>
                                        <%
                                            let badgeClass = '';
                                            let statusText = '';
                                            switch(order.status) {
                                                case 'pending':
                                                    badgeClass = 'bg-warning-subtle text-warning border-warning-subtle';
                                                    statusText = 'Pendente';
                                                    break;
                                                case 'confirmed':
                                                    badgeClass = 'bg-info-subtle text-info border-info-subtle';
                                                    statusText = 'Confirmada';
                                                    break;
                                                case 'preparing':
                                                    badgeClass = 'bg-primary-subtle text-primary border-primary-subtle';
                                                    statusText = 'Em Preparação';
                                                    break;
                                                case 'awaiting_courier':
                                                    badgeClass = 'bg-warning-subtle text-warning border-warning-subtle';
                                                    statusText = 'Aguarda Estafeta';
                                                    break;
                                                case 'delivering':
                                                    badgeClass = 'bg-secondary-subtle text-secondary border-secondary-subtle';
                                                    statusText = order.deliveryMethod === 'pickup' ? 'Aguardar Cliente' : 'Com Estafeta';
                                                    break;
                                                case 'delivered':
                                                    badgeClass = 'bg-success-subtle text-success border-success-subtle';
                                                    statusText = 'Entregue';
                                                    break;
                                                case 'cancelled':
                                                    badgeClass = 'bg-danger-subtle text-danger border-danger-subtle';
                                                    statusText = 'Cancelada';
                                                    break;
                                                default:
                                                    badgeClass = 'bg-light text-dark';
                                                    statusText = order.status;
                                            }
                                        %>
                                        <span class="badge border <%= badgeClass %> px-2 py-1"><%= statusText %></span>
                                    </td>

                                    <td class="text-end pe-4">
                                        <% if (order.status === 'pending') { %>
                                            <button class="btn btn-sm btn-success" onclick="updateOrderStatus('<%= order._id %>', 'confirmed')">
                                                <i class="bi bi-check-lg me-1"></i> Confirmar
                                            </button>
                                        <% } else if (order.status === 'confirmed') { %>
                                            <button class="btn btn-sm btn-primary" onclick="updateOrderStatus('<%= order._id %>', 'preparing')">
                                                <i class="bi bi-box-seam me-1"></i> Preparar
                                            </button>
                                        <% } else if (order.status === 'preparing') { %>
                                            <% if (order.deliveryMethod === 'courier') { %>
                                                <button class="btn btn-sm btn-warning" onclick="updateOrderStatus('<%= order._id %>', 'awaiting_courier')">
                                                    <i class="bi bi-clock me-1"></i> Aguarda Estafeta
                                                </button>
                                            <% } else { %>
                                                <button class="btn btn-sm btn-info text-white" onclick="updateOrderStatus('<%= order._id %>', 'delivering')">
                                                    <i class="bi bi-send me-1"></i> Pronta
                                                </button>
                                            <% } %>
                                        <% } else if (order.status === 'awaiting_courier') { %>
                                            <button class="btn btn-sm btn-info text-white" onclick="updateOrderStatus('<%= order._id %>', 'delivering')">
                                                <i class="bi bi-bicycle me-1"></i> A Caminho
                                            </button>
                                        <% } else { %>
                                            <button class="btn btn-sm btn-light border disabled text-muted" aria-disabled="true">
                                                <i class="bi bi-lock-fill me-1"></i> Bloqueado
                                            </button>
                                        <% } %>
                                    </td>
                                </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="8" class="text-center py-5 text-muted">
                                        <i class="bi bi-inbox fs-1 d-block mb-3 opacity-50"></i>
                                        Não existem encomendas registadas na sua loja.
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>

                    </table>
                </div>
            </div>
        </div>

    </main>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/scripts/orders.js"></script>
</body>
</html>

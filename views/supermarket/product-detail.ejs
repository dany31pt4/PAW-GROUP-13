<!DOCTYPE html>
<html lang="pt">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= product.name %> — Marketplace</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/style/admin.css">
    <link rel="stylesheet" href="/style/supermarket.css">
</head>

<body class="bg-light">

    <%- include('../partials/sidebar-supermarket', { activePage: 'products' }) %>

    <main class="main-wrapper p-4">

        <div class="d-flex align-items-center mb-4 gap-3">
            <a href="/supermarket/products" class="btn btn-light border shadow-sm" style="border-radius: 10px;">
                <i class="bi bi-arrow-left me-1"></i> Voltar
            </a>
            <div>
                <h3 id="product-name-title" class="fw-bold text-dark mb-1"><%= product.name %></h3>
                <p class="text-secondary small mb-0">Detalhes do produto</p>
            </div>
        </div>

        <div class="row g-4">

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm" style="border-radius: 14px; overflow: hidden;">
                    <img id="product-image"
                         src="<%= product.image || 'https://t4.ftcdn.net/jpg/05/97/47/95/360_F_597479556_7bbQ7t4Z8k3xbAloHFHVdZIizWK1PdOo.jpg' %>"
                         onerror="this.src='https://t4.ftcdn.net/jpg/05/97/47/95/360_F_597479556_7bbQ7t4Z8k3xbAloHFHVdZIizWK1PdOo.jpg'"
                         class="w-100" style="height: 280px; object-fit: cover;">

                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center">
                            <span id="product-price" class="fs-3 fw-bold text-dark"><%= (product.price || 0).toFixed(2) %>€</span>
                            <% if (product.isActive) { %>
                                <span id="product-status-badge" class="badge bg-success bg-opacity-10 text-success border border-success-subtle px-3 py-2 rounded-pill">
                                    <i class="bi bi-circle-fill me-1" style="font-size: 8px;"></i>Ativo
                                </span>
                            <% } else { %>
                                <span id="product-status-badge" class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary-subtle px-3 py-2 rounded-pill">
                                    <i class="bi bi-circle me-1" style="font-size: 8px;"></i>Inativo
                                </span>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card border-0 shadow-sm h-100" style="border-radius: 14px;">
                    <div class="card-body p-4">

                        <h5 class="fw-semibold text-dark mb-4">Informações do Produto</h5>

                        <div class="row g-3 mb-4">
                            <div class="col-sm-6">
                                <div class="p-3 rounded-3 bg-light border">
                                    <div class="text-muted small mb-1"><i class="bi bi-tag me-1"></i>Categoria</div>
                                    <div id="product-category" class="fw-semibold text-dark">
                                        <% if (product.category && product.category.name) { %>
                                            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary-subtle px-2 py-1">
                                                <%= product.category.name %>
                                            </span>
                                        <% } else { %>
                                            <span class="text-muted">Sem categoria</span>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="p-3 rounded-3 bg-light border">
                                    <div class="text-muted small mb-1"><i class="bi bi-boxes me-1"></i>Stock Disponível</div>
                                    <div id="product-stock" class="fw-semibold">
                                        <% if (product.stock <= 5) { %>
                                            <span class="text-danger fs-5 fw-bold">
                                                <i class="bi bi-exclamation-circle me-1"></i><%= product.stock %> unid.
                                            </span>
                                            <div class="text-danger small">Stock baixo</div>
                                        <% } else { %>
                                            <span class="text-dark fs-5"><%= product.stock %> unid.</span>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="p-3 rounded-3 bg-light border">
                                    <div class="text-muted small mb-1"><i class="bi bi-calendar3 me-1"></i>Criado em</div>
                                    <div class="fw-semibold text-dark">
                                        <%= new Date(product.createdAt).toLocaleDateString('pt-PT', { day: '2-digit', month: 'long', year: 'numeric' }) %>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="p-3 rounded-3 bg-light border">
                                    <div class="text-muted small mb-1"><i class="bi bi-pencil-square me-1"></i>Última atualização</div>
                                    <div id="product-updated" class="fw-semibold text-dark">
                                        <%= new Date(product.updatedAt).toLocaleDateString('pt-PT', { day: '2-digit', month: 'long', year: 'numeric' }) %>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div id="product-description-wrapper" class="mb-4">
                            <% if (product.description) { %>
                                <div class="text-muted small mb-2"><i class="bi bi-text-left me-1"></i>Descrição</div>
                                <p class="text-dark mb-0" style="line-height: 1.7;"><%= product.description %></p>
                            <% } %>
                        </div>

                        <div class="d-flex gap-2 flex-wrap mt-4 pt-3 border-top">
                            <button class="btn btn-primary px-4" onclick="openEditModal('<%= product._id %>')" style="border-radius: 10px;">
                                <i class="bi bi-pencil me-2"></i>Editar Produto
                            </button>
                            <button id="toggle-btn" class="btn btn-outline-<%= product.isActive ? 'warning' : 'success' %> px-4"
                                    onclick="toggleFromDetail('<%= product._id %>', '<%= product.isActive %>')"
                                    style="border-radius: 10px;">
                                <i class="bi bi-toggle-<%= product.isActive ? 'on' : 'off' %> me-2"></i>
                                <%= product.isActive ? 'Desativar' : 'Ativar' %>
                            </button>
                            <button class="btn btn-outline-danger px-4" onclick="deleteFromDetail('<%= product._id %>')" style="border-radius: 10px;">
                                <i class="bi bi-trash me-2"></i>Eliminar
                            </button>
                        </div>

                    </div>
                </div>
            </div>

        </div>

    </main>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/scripts/products.js"></script>

    <script>
        const PRODUCT_ID = '<%= product._id %>';
        const FALLBACK_IMG = 'https://t4.ftcdn.net/jpg/05/97/47/95/360_F_597479556_7bbQ7t4Z8k3xbAloHFHVdZIizWK1PdOo.jpg';

        // products.js chama loadProductTable() após editar — substituímos pelo refresh desta página
        function loadProductTable() {
            refreshProductDetail(PRODUCT_ID);
        }

        async function refreshProductDetail(id) {
            const res = await fetch(`/api/product/${id}`);
            const data = await res.json();
            if (res.ok) updateDetailUI(data.data);
        }

        function updateDetailUI(p) {
            document.title = `${p.name} — Marketplace`;
            document.getElementById('product-name-title').textContent = p.name;
            document.getElementById('product-image').src = p.image || FALLBACK_IMG;
            document.getElementById('product-price').textContent = `${(p.price || 0).toFixed(2)}€`;
            document.getElementById('product-updated').textContent =
                new Date(p.updatedAt).toLocaleDateString('pt-PT', { day: '2-digit', month: 'long', year: 'numeric' });

            const statusEl = document.getElementById('product-status-badge');
            if (p.isActive) {
                statusEl.className = 'badge bg-success bg-opacity-10 text-success border border-success-subtle px-3 py-2 rounded-pill';
                statusEl.innerHTML = '<i class="bi bi-circle-fill me-1" style="font-size:8px"></i>Ativo';
            } else {
                statusEl.className = 'badge bg-secondary bg-opacity-10 text-secondary border border-secondary-subtle px-3 py-2 rounded-pill';
                statusEl.innerHTML = '<i class="bi bi-circle me-1" style="font-size:8px"></i>Inativo';
            }

            const catEl = document.getElementById('product-category');
            if (p.category && p.category.name) {
                catEl.innerHTML = `<span class="badge bg-primary bg-opacity-10 text-primary border border-primary-subtle px-2 py-1">${p.category.name}</span>`;
            } else {
                catEl.innerHTML = '<span class="text-muted">Sem categoria</span>';
            }

            const stockEl = document.getElementById('product-stock');
            if (p.stock <= 5) {
                stockEl.innerHTML = `<span class="text-danger fs-5 fw-bold"><i class="bi bi-exclamation-circle me-1"></i>${p.stock} unid.</span><div class="text-danger small">Stock baixo</div>`;
            } else {
                stockEl.innerHTML = `<span class="text-dark fs-5">${p.stock} unid.</span>`;
            }

            const descEl = document.getElementById('product-description-wrapper');
            if (p.description) {
                descEl.innerHTML = `<div class="text-muted small mb-2"><i class="bi bi-text-left me-1"></i>Descrição</div><p class="text-dark mb-0" style="line-height:1.7">${p.description}</p>`;
            } else {
                descEl.innerHTML = '';
            }

            const toggleBtn = document.getElementById('toggle-btn');
            if (p.isActive) {
                toggleBtn.className = 'btn px-4 btn-outline-warning';
                toggleBtn.innerHTML = '<i class="bi bi-toggle-on me-2"></i>Desativar';
            } else {
                toggleBtn.className = 'btn px-4 btn-outline-success';
                toggleBtn.innerHTML = '<i class="bi bi-toggle-off me-2"></i>Ativar';
            }
            toggleBtn.style.borderRadius = '10px';
            toggleBtn.onclick = () => toggleFromDetail(p._id, p.isActive);
        }

        async function toggleFromDetail(id, isActive) {
            const confirmed = await Swal.fire({
                title: isActive ? 'Desativar produto?' : 'Ativar produto?',
                text: isActive ? 'O produto ficará invisível para os clientes.' : 'O produto ficará visível para os clientes.',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Confirmar',
                cancelButtonText: 'Cancelar',
                confirmButtonColor: isActive ? '#f39c12' : '#27ae60',
            });
            if (!confirmed.isConfirmed) return;

            const res = await fetch(`/api/product/toggle/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            });
            const data = await res.json();
            if (res.ok) {
                refreshProductDetail(id);
            } else {
                Swal.fire('Erro!', data.message || 'Erro ao alterar estado.', 'error');
            }
        }

        async function deleteFromDetail(id) {
            const confirmed = await Swal.fire({
                title: 'Eliminar Produto?',
                text: 'Esta ação não pode ser revertida!',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Sim, eliminar!',
                cancelButtonText: 'Cancelar',
                confirmButtonColor: '#e74c3c',
            });
            if (!confirmed.isConfirmed) return;

            const res = await fetch(`/api/product/delete/${id}`, {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            });
            const data = await res.json();
            if (res.ok && data.success) {
                await Swal.fire('Eliminado!', 'Produto eliminado com sucesso.', 'success');
                window.location.href = '/supermarket/products';
            } else {
                Swal.fire('Erro!', data.message || 'Não foi possível eliminar.', 'error');
            }
        }
    </script>

</body>
</html>

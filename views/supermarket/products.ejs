<!DOCTYPE html>
<html lang="pt">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inventário — Marketplace</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <link rel="stylesheet" href="/style/admin.css">
    <link rel="stylesheet" href="/style/supermarket.css">
</head>

<body class="bg-light">

    <%- include('../partials/sidebar-supermarket', { activePage: 'products' }) %>

    <main class="main-wrapper p-4">
        
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h3 class="fw-bold text-dark mb-1">Gestão de Inventário</h3>
                <p class="text-secondary small mb-0">Adicione e gere os produtos da sua loja.</p>
            </div>
            <button class="btn btn-primary px-4 py-2 shadow-sm" onclick="openAddModal()" style="border-radius: 10px;">
                <i class="bi bi-plus-lg me-2"></i> Adicionar Produto
            </button>
        </div>

        <div class="card border-0 shadow-sm" style="border-radius: 12px; overflow: hidden;">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        
                        <thead class="table-light text-secondary">
                            <tr style="font-size: 0.85rem; letter-spacing: 0.5px;">
                                <th class="ps-4 py-3 border-bottom-0 fw-semibold">PRODUTO</th>
                                <th class="py-3 border-bottom-0 fw-semibold">CATEGORIA</th>
                                <th class="py-3 border-bottom-0 fw-semibold">PREÇO</th>
                                <th class="py-3 border-bottom-0 fw-semibold">STOCK</th>
                                <th class="py-3 border-bottom-0 fw-semibold">ESTADO</th>
                                <th class="text-end pe-4 py-3 border-bottom-0 fw-semibold">AÇÕES</th>
                            </tr>
                        </thead>

                        <tbody id="productTableBody">
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
                                    A carregar produtos...
                                </td>
                            </tr>
                        </tbody>
                        
                    </table>
                </div>
            </div>
        </div>

    </main>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <script src="/scripts/products.js"></script>

</body>
</html>
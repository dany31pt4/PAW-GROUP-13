<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inventário — Marketplace</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    
    <link rel="stylesheet" href="/style/admin.css">
    <link rel="stylesheet" href="/style/supermarket.css">
</head>
<body>

    <%- include('../partials/sidebar-supermarket', { activePage: 'products' }) %>

    <main class="main-wrapper">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h3 class="fw-bold text-white">Gestão de Inventário</h3>
                <p class="text-muted small">Adicione e gere os produtos da sua loja.</p>
            </div>
            <button class="btn btn-primary px-4 py-2" onclick="abrirModalAdicionar()" style="border-radius: 12px;">
                <i class="bi bi-plus-lg me-2"></i> Adicionar Produto
            </button>
        </div>

        <form action="../api/product/create" method="post">
          <input type="submit" value="teste">
        </form>

        <div class="table-card shadow-sm">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr class="text-muted small">
                            <th class="ps-4">PRODUTO</th>
                            <th>CATEGORIA</th>
                            <th>PREÇO</th>
                            <th>STOCK</th>
                            <th class="text-end pe-4">AÇÕES</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (locals.products && products.length > 0) { %>
                            <% products.forEach(product => { %>
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <img src="<%= product.image || 'https://via.placeholder.com/50' %>" class="product-img-sm me-3">
                                        <span class="fw-bold"><%= product.name %></span>
                                    </div>
                                </td>
                                <td><span class="badge bg-dark border border-secondary text-muted"><%= product.category %></span></td>
                                <td class="fw-bold text-white"><%= product.price.toFixed(2) %>€</td>
                                <td>
                                    <% if(product.stock <= 5) { %>
                                        <span class="text-danger small fw-bold">Baixo: <%= product.stock %></span>
                                    <% } else { %>
                                        <span class="text-muted"><%= product.stock %> unid.</span>
                                    <% } %>
                                </td>
                                <td class="text-end pe-4">
                                    <button class="btn-action" onclick="abrirModalEditar('<%= JSON.stringify(product) %>')"><i class="bi bi-pencil"></i></button>
                                    <button class="btn-action btn-delete ms-2" onclick="confirmarEliminar('<%= product._id %>')"><i class="bi bi-trash"></i></button>
                                </td>
                            </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="5" class="text-center py-5 text-muted">Nenhum produto encontrado.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        const swalDark = Swal.mixin({
            background: '#1e1e1e',
            color: '#fff',
            confirmButtonColor: '#3498db',
            cancelButtonColor: '#2a2a2a',
            customClass: {
                confirmButton: 'px-4 py-2 rounded-3',
                cancelButton: 'px-4 py-2 rounded-3'
            }
        });

        function abrirModalAdicionar() {
            swalDark.fire({
                title: 'Novo Produto',
                html: `
                    <form id="formAdicionar" action="/supermarket/products" method="POST" class="text-start mt-3">
                        <div class="mb-3">
                            <label class="form-label-small">Nome do Produto</label>
                            <input type="text" name="name" class="form-control-custom w-100" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label-small">URL da Imagem</label>
                            <input type="text" name="image" class="form-control-custom w-100">
                        </div>
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label-small">Preço (€)</label>
                                <input type="number" step="0.01" name="price" class="form-control-custom w-100" required>
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label-small">Stock</label>
                                <input type="number" name="stock" class="form-control-custom w-100" required>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label-small">Categoria</label>
                            <select name="category" class="form-control-custom w-100">
                                <option value="Frescos">Frescos</option>
                                <option value="Bebidas">Bebidas</option>
                                <option value="Padaria">Padaria</option>
                                <option value="Mercearia">Mercearia</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label-small">Descrição</label>
                            <textarea name="description" class="form-control-custom w-100" rows="3"></textarea>
                        </div>
                    </form>
                `,
                showCancelButton: true,
                confirmButtonText: 'Guardar Produto',
                cancelButtonText: 'Cancelar',
                preConfirm: () => {
                    const form = document.getElementById('formAdicionar');
                    if (!form.checkValidity()) {
                        form.reportValidity();
                        return false;
                    }
                    form.submit();
                }
            });
        }

        function confirmarEliminar(id) {
            swalDark.fire({
                title: 'Eliminar Produto?',
                text: "Esta ação não pode ser revertida!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Sim, eliminar!',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = `/supermarket/products/delete/${id}`;
                }
            });
        }
    </script>
</body>
</html>
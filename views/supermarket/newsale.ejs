<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nova Venda - Marketplace</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="/style/admin.css" />
</head>
<body>
    <%- include('../partials/sidebar-supermarket', { activePage: 'newsale' }) %>

    <main class="main-wrapper" data-delivery-fee="<%= supermarket.deliveryCost || 0 %>">
        <div class="mb-4">
            <h4 class="fw-bold">Nova Venda</h4>
            <p class="text-muted">Ponto de venda — <%= supermarket.name %></p>
        </div>

        <div class="row g-4">

            <!-- Esquerda: Cliente + Produtos -->
            <div class="col-lg-8">

                <!-- 1. Cliente -->
                <div class="table-card mt-0 mb-4">
                    <h6 class="fw-bold mb-3"><i class="bi bi-person me-2"></i>1. Cliente</h6>

                    <div id="clientSearchBlock">
                        <div class="input-group">
                            <input type="text" id="clientSearch" class="form-control" placeholder="Pesquisar por email...">
                            <button class="btn btn-primary" type="button" onclick="searchClient()">Procurar</button>
                        </div>
                        <div class="text-end mt-2">
                            <button class="btn btn-sm btn-link text-muted text-decoration-none" onclick="toggleNewClientForm()">
                                <i class="bi bi-plus-circle me-1"></i> Criar novo cliente
                            </button>
                        </div>
                    </div>

                    <div id="selectedClientBlock" class="d-none p-3 bg-light rounded border d-flex justify-content-between align-items-center">
                        <div>
                            <i class="bi bi-check-circle-fill text-success me-2"></i>
                            <span id="clientNameDisplay" class="fw-bold"></span>
                            <span id="clientEmailDisplay" class="text-muted ms-2 small"></span>
                        </div>
                        <button class="btn btn-sm btn-outline-danger" onclick="resetClient()">Alterar</button>
                    </div>

                    <div id="newClientForm" class="d-none mt-3 p-3 border rounded bg-light">
                        <h6 class="fw-bold mb-3">Novo Cliente</h6>
                        <div class="row g-2">
                            <div class="col-md-6">
                                <input type="text" id="nc-name" class="form-control" placeholder="Nome">
                            </div>
                            <div class="col-md-6">
                                <input type="email" id="nc-email" class="form-control" placeholder="Email">
                            </div>
                            <div class="col-md-6">
                                <input type="text" id="nc-phone" class="form-control" placeholder="Telefone">
                            </div>
                            <div class="col-md-6">
                                <input type="password" id="nc-password" class="form-control" placeholder="Password temporária">
                            </div>
                            <div class="col-12 text-end">
                                <button class="btn btn-sm btn-secondary me-2" onclick="toggleNewClientForm()">Cancelar</button>
                                <button class="btn btn-sm btn-success" onclick="createClient()">Criar e Selecionar</button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 2. Produtos -->
                <div class="table-card mt-0">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="fw-bold m-0"><i class="bi bi-box-seam me-2"></i>2. Produtos</h6>
                        <div class="d-flex gap-2">
                            <input type="text" id="prodSearch" class="form-control form-control-sm" placeholder="Procurar..." onkeyup="filterProducts()">
                            <select id="catFilter" class="form-select form-select-sm" style="width:160px" onchange="filterProducts()">
                                <option value="all">Todas as categorias</option>
                                <% categories.forEach(cat => { %>
                                    <option value="<%= cat._id %>"><%= cat.name %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Produto</th>
                                    <th>Categoria</th>
                                    <th>Preço</th>
                                    <th>Stock</th>
                                    <th class="text-end">Ação</th>
                                </tr>
                            </thead>
                            <tbody id="productTableBody">
                                <% if (products.length === 0) { %>
                                    <tr><td colspan="5" class="text-center text-muted py-4">Nenhum produto com stock disponível.</td></tr>
                                <% } else { %>
                                    <% products.forEach(p => { %>
                                        <tr class="product-row"
                                            data-id="<%= p._id %>"
                                            data-name="<%= p.name.toLowerCase() %>"
                                            data-cat="<%= p.category ? p.category._id : '' %>">
                                            <td><strong><%= p.name %></strong></td>
                                            <td><span class="badge bg-light text-dark border"><%= p.category ? p.category.name : '-' %></span></td>
                                            <td><%= p.price.toFixed(2) %>€</td>
                                            <td><span class="stock-display"><%= p.stock %></span></td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-outline-primary"
                                                    data-id="<%= p._id %>"
                                                    data-label="<%= p.name.replace(/"/g, '&quot;') %>"
                                                    data-price="<%= p.price %>"
                                                    data-stock="<%= p.stock %>"
                                                    onclick="addToCart(this)">
                                                    <i class="bi bi-plus"></i> Adicionar
                                                </button>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>

            <!-- Direita: Carrinho -->
            <div class="col-lg-4">
                <div class="table-card mt-0" style="position: sticky; top: 20px;">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="fw-bold m-0"><i class="bi bi-cart3 me-2"></i>3. Resumo</h6>
                        <button class="btn btn-sm btn-outline-danger" onclick="clearCart()"><i class="bi bi-trash"></i></button>
                    </div>

                    <div id="cartItemsList" style="min-height: 100px; max-height: 300px; overflow-y: auto;">
                        <p class="text-muted text-center small py-3" id="emptyCartMsg">O carrinho está vazio.</p>
                    </div>

                    <hr>

                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted">Método de Entrega</label>
                        <select id="deliveryMethod" class="form-select form-select-sm" onchange="onDeliveryChange()">
                            <option value="pickup">Levantamento em Loja (0.00€)</option>
                            <option value="courier">Estafeta (+<%= (supermarket.deliveryCost || 0).toFixed(2) %>€)</option>
                        </select>
                    </div>

                    <div id="addressBlock" class="mb-3 d-none">
                        <label class="form-label small fw-bold text-muted">Morada de Entrega <span class="text-danger">*</span></label>
                        <input type="text" id="deliveryAddress" class="form-control form-control-sm" placeholder="Rua, número, cidade..." oninput="checkSaleValidity()">
                    </div>

                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted small">Subtotal</span>
                        <span id="subtotalDisplay" class="fw-bold">0.00€</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="fw-bold">Total</span>
                        <span id="totalDisplay" class="fw-bold fs-5 text-primary">0.00€</span>
                    </div>

                    <button id="btnConfirmSale" class="btn btn-primary w-100" onclick="processSale()" disabled>
                        <i class="bi bi-check-circle me-2"></i>Finalizar Venda
                    </button>
                </div>
            </div>

        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/scripts/newsale.js"></script>
</body>
</html>

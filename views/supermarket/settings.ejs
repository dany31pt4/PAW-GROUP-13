<!DOCTYPE html>
<html lang="pt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Painel de Administração - Marketplace</title>

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css"
    />

    <link rel="stylesheet" href="/style/admin.css" />
  </head>

  <body>
    <%- include('../partials/sidebar-supermarket') %>

    <main class="main-wrapper">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <h4 style="font-weight: 700; color: #2c3e50; margin: 0">
            Painel de administração
          </h4>
          <small class="text-muted"
            >Olá,
            <strong> <%= supermarket.name %> </strong>
          </small>
        </div>

        <!-- 
         o supermercado pode configurar:
                 Dados do supermercado:
                - Nome
                - Descrição
                - Localização
                - Horário de funcionamento

                Métodos de entrega:
                - Ativar/desativar levantamento em loja
                - Ativar/desativar entrega por estafeta
                - Custo de entrega por método

                Dados da conta (utilizador):
                - Email
                - Password
                - Telefone

            -->
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>

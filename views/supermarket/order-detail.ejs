<!DOCTYPE html>
<html lang="pt">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Encomenda #<%= order._id %> — Marketplace</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/style/admin.css">
    <link rel="stylesheet" href="/style/supermarket.css">
</head>

<body class="bg-light">

    <%- include('../partials/sidebar-supermarket', { activePage: 'orders' }) %>

    <main class="main-wrapper p-4">

        <div class="d-flex align-items-center mb-4 gap-3">
            <a href="/supermarket/orders" class="btn btn-light border shadow-sm" style="border-radius: 10px;">
                <i class="bi bi-arrow-left me-1"></i> Voltar
            </a>
            <div>
                <h3 class="fw-bold text-dark mb-1">Detalhes da Encomenda</h3>
                <p class="text-secondary small mb-0 font-monospace">#<%= order._id %></p>
            </div>
        </div>

        <div class="row g-4">

            <%
                const statusMap = {
                    pending:          { badge: 'bg-warning-subtle text-warning border-warning-subtle',     label: 'Pendente' },
                    confirmed:        { badge: 'bg-info-subtle text-info border-info-subtle',               label: 'Confirmada' },
                    preparing:        { badge: 'bg-primary-subtle text-primary border-primary-subtle',     label: 'Em Preparação' },
                    awaiting_courier: { badge: 'bg-warning-subtle text-warning border-warning-subtle',     label: 'Aguarda Estafeta' },
                    delivering:       { badge: 'bg-secondary-subtle text-secondary border-secondary-subtle', label: order.deliveryMethod === 'pickup' ? 'Aguardar Cliente' : 'Com Estafeta' },
                    delivered:        { badge: 'bg-success-subtle text-success border-success-subtle',     label: 'Entregue' },
                    cancelled:        { badge: 'bg-danger-subtle text-danger border-danger-subtle',        label: 'Cancelada' },
                };
                const current = statusMap[order.status] || { badge: 'bg-light text-dark', label: order.status };
            %>

            <!-- Coluna esquerda: resumo -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm" style="border-radius: 14px;">
                    <div class="card-body p-4">

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="fw-semibold text-dark mb-0">Resumo</h5>
                            <span id="order-status-badge" class="badge border <%= current.badge %> px-3 py-2"><%= current.label %></span>
                        </div>

                        <div class="mb-3">
                            <div class="text-muted small mb-1"><i class="bi bi-person me-1"></i>Cliente</div>
                            <div class="fw-semibold text-dark"><%= order.customer ? order.customer.name : 'N/A' %></div>
                            <% if (order.customer && order.customer.email) { %>
                                <div class="text-muted small"><%= order.customer.email %></div>
                            <% } %>
                        </div>

                        <div class="mb-3">
                            <div class="text-muted small mb-1"><i class="bi bi-calendar3 me-1"></i>Data</div>
                            <div class="fw-semibold text-dark">
                                <%= new Date(order.createdAt).toLocaleDateString('pt-PT', { day: '2-digit', month: 'long', year: 'numeric' }) %>
                            </div>
                            <div class="text-muted small">
                                <%= new Date(order.createdAt).toLocaleTimeString('pt-PT', { hour: '2-digit', minute: '2-digit' }) %>
                            </div>
                        </div>

                        <div class="mb-3">
                            <div class="text-muted small mb-1"><i class="bi bi-truck me-1"></i>Método de entrega</div>
                            <% if (order.deliveryMethod === 'pickup') { %>
                                <span class="badge bg-light text-dark border"><i class="bi bi-shop me-1"></i>Levantamento</span>
                            <% } else { %>
                                <span class="badge bg-light text-dark border"><i class="bi bi-bicycle me-1"></i>Estafeta</span>
                            <% } %>
                        </div>

                        <hr>

                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-muted small">Subtotal</span>
                            <span class="fw-semibold"><%= (order.total).toFixed(2) %> €</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted small">Entrega</span>
                            <span class="fw-semibold"><%= (order.deliveryCost).toFixed(2) %> €</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="fw-bold">Total</span>
                            <span class="fw-bold fs-5"><%= (order.total + order.deliveryCost).toFixed(2) %> €</span>
                        </div>

                    </div>
                </div>

                <!-- Botão de ação -->
                <div id="order-action-wrapper" class="mt-3">
                    <% if (order.status === 'pending') { %>
                        <button class="btn btn-success w-100" onclick="updateOrderStatus('<%= order._id %>', 'confirmed')">
                            <i class="bi bi-check-lg me-1"></i>Confirmar
                        </button>
                    <% } else if (order.status === 'confirmed') { %>
                        <button class="btn btn-primary w-100" onclick="updateOrderStatus('<%= order._id %>', 'preparing')">
                            <i class="bi bi-box-seam me-1"></i>Preparar
                        </button>
                    <% } else if (order.status === 'preparing') { %>
                        <% if (order.deliveryMethod === 'courier') { %>
                            <button class="btn btn-warning w-100" onclick="updateOrderStatus('<%= order._id %>', 'awaiting_courier')">
                                <i class="bi bi-clock me-1"></i>Aguarda Estafeta
                            </button>
                        <% } else { %>
                            <button class="btn btn-info text-white w-100" onclick="updateOrderStatus('<%= order._id %>', 'delivering')">
                                <i class="bi bi-send me-1"></i>Pronta
                            </button>
                        <% } %>
                    <% } else if (order.status === 'awaiting_courier') { %>
                        <button class="btn btn-info text-white w-100" onclick="updateOrderStatus('<%= order._id %>', 'delivering')">
                            <i class="bi bi-bicycle me-1"></i>A Caminho
                        </button>
                    <% } else { %>
                        <button class="btn btn-light border w-100 disabled text-muted" aria-disabled="true">
                            <i class="bi bi-lock-fill me-1"></i>Bloqueado
                        </button>
                    <% } %>
                </div>

            </div>

            <!-- Coluna direita: produtos -->
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm h-100" style="border-radius: 14px;">
                    <div class="card-body p-4">

                        <h5 class="fw-semibold text-dark mb-4">Produtos da Encomenda</h5>

                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead class="table-light text-secondary" style="font-size: 0.82rem; letter-spacing: 0.5px;">
                                    <tr>
                                        <th class="ps-3 py-2 border-bottom-0 fw-semibold">PRODUTO</th>
                                        <th class="py-2 border-bottom-0 fw-semibold text-center">QTD.</th>
                                        <th class="py-2 border-bottom-0 fw-semibold text-end">PREÇO UNIT.</th>
                                        <th class="py-2 border-bottom-0 fw-semibold text-end pe-3">SUBTOTAL</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% order.products.forEach(item => { %>
                                        <tr>
                                            <td class="ps-3 py-3">
                                                <% if (item.product && item.product.image) { %>
                                                    <img src="<%= item.product.image %>"
                                                         onerror="this.src='https://t4.ftcdn.net/jpg/05/97/47/95/360_F_597479556_7bbQ7t4Z8k3xbAloHFHVdZIizWK1PdOo.jpg'"
                                                         class="rounded-2 me-2 shadow-sm" style="width:40px;height:40px;object-fit:cover;">
                                                <% } %>
                                                <span class="fw-semibold text-dark">
                                                    <%= item.product ? item.product.name : 'Produto Indisponível' %>
                                                </span>
                                            </td>
                                            <td class="text-center fw-bold"><%= item.quantity %></td>
                                            <td class="text-end"><%= (item.unitPrice || 0).toFixed(2) %> €</td>
                                            <td class="text-end pe-3 fw-bold"><%= ((item.unitPrice || 0) * item.quantity).toFixed(2) %> €</td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>

                    </div>
                </div>
            </div>

        </div>

    </main>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/scripts/orders.js"></script>

    <script>
        const ORDER_ID = '<%= order._id %>';

        // orders.js chama window.location.reload() após atualizar — substituímos por refresh da página
        async function updateOrderStatus(orderId, newStatus) {
            let actionText = '';
            let actionColor = '';

            if (newStatus === 'confirmed') { actionText = 'confirmar esta encomenda'; actionColor = '#198754'; }
            else if (newStatus === 'preparing') { actionText = 'iniciar a preparação desta encomenda'; actionColor = '#0d6efd'; }
            else if (newStatus === 'awaiting_courier') { actionText = 'marcar esta encomenda a aguardar estafeta'; actionColor = '#ffc107'; }
            else if (newStatus === 'delivering') { actionText = 'marcar esta encomenda como a caminho'; actionColor = '#0dcaf0'; }

            const confirmed = await Swal.fire({
                title: 'Confirmar ação',
                text: `Pretende ${actionText}?`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: actionColor,
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Sim, atualizar!',
                cancelButtonText: 'Cancelar',
            });
            if (!confirmed.isConfirmed) return;

            Swal.fire({ title: 'A processar...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });

            const res = await fetch(`/api/orders/status/${orderId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                body: JSON.stringify({ status: newStatus }),
            });
            const data = await res.json();

            if (res.ok) {
                await Swal.fire('Sucesso!', 'O estado da encomenda foi atualizado.', 'success');
                refreshOrderDetail(orderId);
            } else {
                Swal.fire('Erro!', data.message || 'Não foi possível atualizar o estado.', 'error');
            }
        }

        async function refreshOrderDetail(id) {
            const res = await fetch(`/api/orders/${id}`);
            const data = await res.json();
            if (res.ok) updateOrderUI(data.data || data);
        }

        function updateOrderUI(o) {
            const statusMap = {
                pending:          { badge: 'bg-warning-subtle text-warning border-warning-subtle',       label: 'Pendente' },
                confirmed:        { badge: 'bg-info-subtle text-info border-info-subtle',                 label: 'Confirmada' },
                preparing:        { badge: 'bg-primary-subtle text-primary border-primary-subtle',       label: 'Em Preparação' },
                awaiting_courier: { badge: 'bg-warning-subtle text-warning border-warning-subtle',       label: 'Aguarda Estafeta' },
                delivering:       { badge: 'bg-secondary-subtle text-secondary border-secondary-subtle', label: o.deliveryMethod === 'pickup' ? 'Aguardar Cliente' : 'Com Estafeta' },
                delivered:        { badge: 'bg-success-subtle text-success border-success-subtle',       label: 'Entregue' },
                cancelled:        { badge: 'bg-danger-subtle text-danger border-danger-subtle',          label: 'Cancelada' },
            };
            const current = statusMap[o.status] || { badge: 'bg-light text-dark', label: o.status };

            const statusEl = document.getElementById('order-status-badge');
            statusEl.className = `badge border ${current.badge} px-3 py-2`;
            statusEl.textContent = current.label;

            const actionWrapper = document.getElementById('order-action-wrapper');
            let btn = '';
            if (o.status === 'pending') {
                btn = `<button class="btn btn-success w-100" onclick="updateOrderStatus('${o._id}', 'confirmed')"><i class="bi bi-check-lg me-1"></i>Confirmar</button>`;
            } else if (o.status === 'confirmed') {
                btn = `<button class="btn btn-primary w-100" onclick="updateOrderStatus('${o._id}', 'preparing')"><i class="bi bi-box-seam me-1"></i>Preparar</button>`;
            } else if (o.status === 'preparing') {
                if (o.deliveryMethod === 'courier') {
                    btn = `<button class="btn btn-warning w-100" onclick="updateOrderStatus('${o._id}', 'awaiting_courier')"><i class="bi bi-clock me-1"></i>Aguarda Estafeta</button>`;
                } else {
                    btn = `<button class="btn btn-info text-white w-100" onclick="updateOrderStatus('${o._id}', 'delivering')"><i class="bi bi-send me-1"></i>Pronta</button>`;
                }
            } else if (o.status === 'awaiting_courier') {
                btn = `<button class="btn btn-info text-white w-100" onclick="updateOrderStatus('${o._id}', 'delivering')"><i class="bi bi-bicycle me-1"></i>A Caminho</button>`;
            } else {
                btn = `<button class="btn btn-light border w-100 disabled text-muted" aria-disabled="true"><i class="bi bi-lock-fill me-1"></i>Bloqueado</button>`;
            }
            actionWrapper.innerHTML = btn;
        }
    </script>

</body>
</html>

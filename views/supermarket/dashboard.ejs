<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Painel Supermercado - Marketplace</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    
    <link rel="stylesheet" href="/style/admin.css">
    <link rel="stylesheet" href="/style/supermarket.css">
</head>
<body>

    <%- include('../partials/sidebar-supermarket') %>

    <main class="main-wrapper">

        <div class="dash-header">
            <div class="dash-header-left">
                <h2>Gestão da Loja</h2>
                <p>Olá, <strong><%= supermarketName %></strong> — bem-vindo de volta</p>
            </div>
            <div class="dash-header-right">
                <div class="badge-active <%= typeof marketStatus !== 'undefined' && marketStatus === 'approved' ? 'approved' : 'pending' %>">
                    <span class="dot-pulse"></span>
                    <%= typeof marketStatus !== 'undefined' && marketStatus === 'approved' ? 'Loja Ativa' : 'Pendente' %>
                </div>
                <div class="avatar-circle">
                    <%= supermarketName ? supermarketName.slice(0,2).toUpperCase() : 'SM' %>
                </div>
            </div>
        </div>

        <div class="stats-grid">

            <div class="stat-card sc-blue">
                <div class="stat-icon">
                    <i class="bi bi-box-seam"></i>
                </div>
                <div class="stat-info">
                    <div class="stat-label">Total Encomendas</div>
                    <div class="stat-val" data-target="<%= totalOrders %>">0</div>
                    <div class="stat-trend trend-up">
                        <i class="bi bi-arrow-up-short"></i> Em crescimento
                    </div>
                </div>
            </div>

            <div class="stat-card sc-green">
                <div class="stat-icon">
                    <i class="bi bi-bag-check"></i>
                </div>
                <div class="stat-info">
                    <div class="stat-label">Produtos Ativos</div>
                    <div class="stat-val" data-target="<%= totalProducts %>">0</div>
                    <div class="stat-trend trend-up">
                        <i class="bi bi-check-circle"></i> Catálogo atualizado
                    </div>
                </div>
            </div>

            <div class="stat-card sc-orange">
                <div class="stat-icon">
                    <i class="bi bi-exclamation-triangle"></i>
                </div>
                <div class="stat-info">
                    <div class="stat-label">Stock Crítico</div>
                    <div class="stat-val" data-target="<%= typeof lowStockCount !== 'undefined' ? lowStockCount : 0 %>">0</div>
                    <div class="stat-trend trend-down">
                        <i class="bi bi-arrow-down-short"></i> Requer atenção
                    </div>
                </div>
            </div>

            <div class="stat-card sc-red">
                <div class="stat-icon">
                    <i class="bi bi-graph-up-arrow"></i>
                </div>
                <div class="stat-info">
                    <div class="stat-label">Vendas Hoje</div>
                    <div class="stat-val" data-target="<%= typeof ordersToday !== 'undefined' ? ordersToday : 0 %>">0</div>
                    <div class="stat-trend trend-up">
                        <i class="bi bi-calendar-day"></i> Referente a hoje
                    </div>
                </div>
            </div>

        </div>

        <div class="charts-row">
            <div class="chart-card">
                <h6><i class="bi bi-graph-up me-2"></i>Desempenho de Vendas</h6>
                <p class="chart-sub">Últimos 7 dias — encomendas por dia</p>
                <div class="chart-wrap">
                    <canvas id="salesChart"></canvas>
                </div>
            </div>

            <div class="chart-card">
                <h6><i class="bi bi-pie-chart-fill me-2"></i>Distribuição de Stock</h6>
                <p class="chart-sub">Estado atual do inventário</p>
                <div class="chart-wrap-sm">
                    <canvas id="stockChart"></canvas>
                </div>
                <div class="chart-legend">
                    <span><span class="leg-dot" style="background:#48cfad"></span>Em Stock</span>
                    <span><span class="leg-dot" style="background:#f7934c"></span>Stock Baixo</span>
                    <span><span class="leg-dot" style="background:#e05c6f"></span>Esgotado</span>
                </div>
            </div>
        </div>

        <div class="table-card mt-4">
            <div class="table-head-bar d-flex justify-content-between align-items-center mb-3">
                <h6 class="m-0 fw-bold">Últimas Encomendas</h6>
                <a href="/supermarket/orders" class="btn btn-sm btn-outline-primary">Ver histórico completo →</a>
            </div>

            <div class="table-responsive">
                <table class="table orders-table align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Cliente</th>
                            <th>Data</th>
                            <th>Estado</th>
                            <th class="text-end">Ação</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (typeof recentOrders !== 'undefined' && recentOrders.length > 0) { %>
                            <% recentOrders.forEach(order => { %>
                            <tr>
                                <td><span class="text-muted fw-bold">#<%= order._id.toString().slice(-6).toUpperCase() %></span></td>
                                <td><strong><%= order.customer ? order.customer.name : 'N/A' %></strong></td>
                                <td class="text-muted"><%= new Date(order.createdAt).toLocaleDateString('pt-PT') %></td>
                                <td>
                                    <% 
                                        let badgeClass = 'bg-secondary-subtle text-secondary';
                                        let statusText = order.status;
                                        if (order.status === 'entregue' || order.status === 'delivered') { badgeClass = 'bg-success-subtle text-success'; statusText = 'Entregue'; }
                                        else if (order.status === 'pendente' || order.status === 'pending') { badgeClass = 'bg-warning-subtle text-warning'; statusText = 'Pendente'; }
                                    %>
                                    <span class="badge border <%= badgeClass %>"><%= statusText %></span>
                                </td>
                                <td class="text-end">
                                    <a href="/supermarket/orders/<%= order._id %>" class="btn btn-sm btn-light border" title="Ver detalhes">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-2 opacity-50"></i>
                                    Nenhuma encomenda registada até ao momento.
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>

    <script>
        /* ── Contadores animados ── */
        function animateCount(el, target, duration) {
            let start = 0;
            const step = target / (duration / 16);
            const id = setInterval(() => {
                start = Math.min(start + step, target);
                el.textContent = Math.round(start);
                if (start >= target) clearInterval(id);
            }, 16);
        }

        document.querySelectorAll('.stat-val[data-target]').forEach((el, i) => {
            const target = parseInt(el.dataset.target) || 0;
            setTimeout(() => animateCount(el, target, 900), 200 + i * 80);
        });

        /* ── Gráfico de Vendas ── */
        new Chart(document.getElementById('salesChart'), {
            type: 'line',
            data: {
                labels: ['Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb', 'Dom'],
                datasets: [{
                    label: 'Encomendas',
                    data: [2, 5, 3, 8, 4, 10, 7],
                    borderColor: '#3498db',
                    backgroundColor: 'rgba(52, 152, 219, 0.1)',
                    fill: true,
                    tension: 0.4,
                    borderWidth: 3,
                    pointBackgroundColor: '#fff',
                    pointBorderColor: '#3498db',
                    pointBorderWidth: 2,
                    pointRadius: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { grid: { display: false } },
                    y: { grid: { borderDash: [5, 5] }, beginAtZero: true }
                }
            }
        });

        /* ── Gráfico de Stock ── */
        new Chart(document.getElementById('stockChart'), {
            type: 'doughnut',
            data: {
                labels: ['Em Stock', 'Stock Baixo', 'Esgotado'],
                datasets: [{
                    data: [
                        <%= totalProducts %>,
                        <%= typeof lowStockCount !== 'undefined' ? lowStockCount : 0 %>,
                        0
                    ],
                    backgroundColor: ['#48cfad', '#f7934c', '#e05c6f'],
                    borderWidth: 0,
                    hoverOffset: 5
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '75%',
                plugins: { legend: { display: false } }
            }
        });
    </script>

</body>
</html>
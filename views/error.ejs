<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Erro <%= error.status || 500 %> — Marketplace</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body class="bg-light d-flex align-items-center justify-content-center" style="min-height: 100vh;">

    <div class="text-center px-4" style="max-width: 480px;">

        <div class="mb-4" style="font-size: 5rem; line-height: 1;">
            <% if (error.status === 404) { %>
                <i class="bi bi-search text-secondary"></i>
            <% } else if (error.status === 403) { %>
                <i class="bi bi-lock-fill text-warning"></i>
            <% } else { %>
                <i class="bi bi-exclamation-triangle-fill text-danger"></i>
            <% } %>
        </div>

        <h1 class="fw-bold text-dark" style="font-size: 4rem;"><%= error.status || 500 %></h1>

        <p class="fs-5 text-muted mb-4"><%= message || 'Ocorreu um erro inesperado.' %></p>

        <a href="javascript:history.back()" class="btn btn-primary px-4 me-2" style="border-radius: 10px;">
            <i class="bi bi-arrow-left me-2"></i>Voltar
        </a>
        <a href="/" class="btn btn-light border px-4" style="border-radius: 10px;">
            <i class="bi bi-house me-2"></i>Início
        </a>

    </div>

</body>
</html>

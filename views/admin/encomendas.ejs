<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Encomendas & Estatísticas - Admin</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/stylesheets/admin.css">
</head>
<body>

    <aside class="sidebar">
        <div class="sidebar-brand">
            <i class="bi bi-box-seam" style="font-size:20px"></i> IPP Marketplace
        </div>
        <nav style="padding: 12px 0;">
            <a href="/admin/dashboard" class="nav-link-item <%= paginaAtiva === 'dashboard' ? 'active' : '' %>">
                <i class="bi bi-grid-1x2"></i> Painel geral
            </a>
            <a href="/admin/aprovacoes" class="nav-link-item <%= paginaAtiva === 'aprovacoes' ? 'active' : '' %>">
                <i class="bi bi-shop-window"></i> Aprovar lojas
                <% if (totalPendentes > 0) { %>
                    <span style="margin-left:auto; background:#e74c3c; color:#fff; border-radius:10px; font-size:11px; padding:1px 7px;"><%= totalPendentes %></span>
                <% } %>
            </a>
            <a href="/admin/utilizadores" class="nav-link-item <%= paginaAtiva === 'utilizadores' ? 'active' : '' %>">
                <i class="bi bi-people"></i> Utilizadores
            </a>
            <a href="/admin/encomendas" class="nav-link-item <%= paginaAtiva === 'encomendas' ? 'active' : '' %>">
                <i class="bi bi-truck"></i> Encomendas
            </a>
            <div style="border-top: 1px solid rgba(255,255,255,0.08); margin: 16px 0;"></div>
            <a href="/auth/login" class="nav-link-item" style="color:#e74c3c;"><i class="bi bi-box-arrow-left"></i> Sair</a>
        </nav>
    </aside>

    <main class="main-wrapper">
        <div class="mb-4">
            <h4 class="fw-bold">Gestão de Encomendas</h4>
            <p class="text-muted">Análise gráfica e listagem de vendas.</p>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="table-card mt-0" style="height: 100%;">
                    <h6 class="fw-bold mb-3"><i class="bi bi-pie-chart-fill me-2"></i>Vendas por Loja</h6>
                    <div style="max-height: 250px; display: flex; justify-content: center;">
                        <canvas id="chartLojas"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="table-card mt-0" style="height: 100%;">
                    <h6 class="fw-bold mb-3"><i class="bi bi-bar-chart-line-fill me-2"></i>Entregas por Estafeta</h6>
                    <canvas id="chartEstafetas"></canvas>
                </div>
            </div>
        </div>

        <div class="table-card">
            <h6 class="fw-bold mb-3">Últimas Transações</h6>
            <div class="table-responsive">
                <table class="table table-hover align-middle" style="font-size:14px">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Cliente</th>
                            <th>Loja</th>
                            <th>Valor</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% listaEncomendas.forEach(function(enc) { %>
                        <tr>
                            <td><span class="text-muted">#<%= enc.id %></span></td>
                            <td><strong><%= enc.cliente %></strong></td>
                            <td><%= enc.loja %></td>
                            <td><%= enc.valor %>€</td>
                            <td>
                                <% if(enc.estado === 'Entregue') { %>
                                    <span class="badge bg-success-subtle text-success border border-success-subtle">Entregue</span>
                                <% } else { %>
                                    <span class="badge bg-warning-subtle text-warning border border-warning-subtle">Pendente</span>
                                <% } %>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        // Gráfico de Lojas (Doughnut)
        const ctxLojas = document.getElementById('chartLojas');
        new Chart(ctxLojas, {
            type: 'doughnut',
            data: {
                labels: ['Pingo Doce', 'Continente', 'Lidl', 'Intermarché'],
                datasets: [{
                    data: [300, 50, 100, 80],
                    backgroundColor: ['#3498db', '#2ecc71', '#f1c40f', '#e74c3c'],
                    hoverOffset: 4
                }]
            },
            options: { plugins: { legend: { position: 'bottom' } } }
        });

        // Gráfico de Estafetas (Barra Horizontal)
        const ctxEstafetas = document.getElementById('chartEstafetas');
        new Chart(ctxEstafetas, {
            type: 'bar',
            data: {
                labels: ['Ricardo', 'Ana', 'Bruno', 'Sofia'],
                datasets: [{
                    label: 'Entregas',
                    data: [12, 19, 10, 15],
                    backgroundColor: '#3498db',
                    borderRadius: 5
                }]
            },
            options: { indexAxis: 'y', plugins: { legend: { display: false } } }
        });
    </script>
</body>
</html>
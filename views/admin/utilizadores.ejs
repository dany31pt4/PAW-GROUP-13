<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestão de Utilizadores - Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/stylesheets/admin.css">
</head>
<body>

    <aside class="sidebar">
        <div class="sidebar-brand">
            <i class="bi bi-box-seam" style="font-size:20px"></i> IPP Marketplace
        </div>
        <nav style="padding: 12px 0;">
            <a href="/admin/dashboard" class="nav-link-item <%= paginaAtiva === 'dashboard' ? 'active' : '' %>">
                <i class="bi bi-grid-1x2"></i> Painel geral
            </a>
            <a href="/admin/aprovacoes" class="nav-link-item <%= paginaAtiva === 'aprovacoes' ? 'active' : '' %>">
                <i class="bi bi-shop-window"></i> Aprovar lojas
                <% if (totalPendentes > 0) { %>
                    <span style="margin-left:auto; background:#e74c3c; color:#fff; border-radius:10px; font-size:11px; padding:1px 7px;"><%= totalPendentes %></span>
                <% } %>
            </a>
            <a href="/admin/utilizadores" class="nav-link-item <%= paginaAtiva === 'utilizadores' ? 'active' : '' %>">
                <i class="bi bi-people"></i> Utilizadores
            </a>
            <a href="/admin/encomendas" class="nav-link-item <%= paginaAtiva === 'encomendas' ? 'active' : '' %>">
                <i class="bi bi-truck"></i> Encomendas
            </a>
            <div style="border-top: 1px solid rgba(255,255,255,0.08); margin: 16px 0;"></div>
            <a href="/auth/login" class="nav-link-item" style="color:#e74c3c;"><i class="bi bi-box-arrow-left"></i> Sair</a>
        </nav>
    </aside>

    <main class="main-wrapper">
        <div class="mb-4">
            <h4 class="fw-bold">Gestão de Utilizadores</h4>
            <p class="text-muted">Consulta e controlo de todas as contas registadas.</p>
        </div>

        <ul class="nav nav-tabs mb-4" id="userTabs" role="tablist">
            <li class="nav-item">
                <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#clientes">Clientes</button>
            </li>
            <li class="nav-item">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#lojas">Supermercados</button>
            </li>
            <li class="nav-item">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#estafetas">Estafetas</button>
            </li>
        </ul>

        <div class="tab-content">
            <div class="tab-pane fade show active" id="clientes">
                <div class="table-card mt-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Nome</th>
                                    <th>Email</th>
                                    <th>Data Registo</th>
                                    <th class="text-end">Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% clientes.forEach(function(c) { %>
                                <tr>
                                    <td><strong><%= c.nome %></strong></td>
                                    <td><%= c.email %></td>
                                    <td><%= c.data %></td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-danger">Suspender</button>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="lojas">
                <div class="table-card mt-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Supermercado</th>
                                    <th>Localidade</th>
                                    <th>Estado</th>
                                    <th class="text-end">Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% lojas.forEach(function(l) { %>
                                <tr>
                                    <td><strong><%= l.nome %></strong></td>
                                    <td><%= l.localidade %></td>
                                    <td><span class="badge bg-success">Ativo</span></td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-light border">Ver Loja</button>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="estafetas">
                <div class="table-card mt-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Estafeta</th>
                                    <th>Veículo</th>
                                    <th>Entregas</th>
                                    <th class="text-end">Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% estafetas.forEach(function(e) { %>
                                <tr>
                                    <td><strong><%= e.nome %></strong></td>
                                    <td><%= e.veiculo %></td>
                                    <td><%= e.totalEntregas %></td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-primary">Contactar</button>
                                    </td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
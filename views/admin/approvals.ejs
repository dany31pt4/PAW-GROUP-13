<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aprovações Pendentes | Marketplace</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/style/admin.css">
</head>
<body>

    <%- include('../partials/sidebar-admin') %>

    <main class="main-content">
        <header class="content-header mb-5">
            <div>
                <h2 class="page-title" style="color: white; font-weight: 700;">Validar Novos Registos</h2>
                <p style="color: #bbb;">Lista completa de supermercados e estafetas à espera de aprovação.</p>
            </div>
        </header>

        <div class="custom-card">
            <div class="table-responsive">
                <table class="table custom-table align-middle">
                    <thead>
                        <tr>    
                            <th class="border-0">ID</th>
                            <th class="border-0">Entidade</th>
                            <th class="border-0">Contacto</th>
                            <th class="border-0">Localidade</th>
                            <th class="border-0 text-end">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (pendingList.length === 0) { %>
                            <tr>
                                <td colspan="5" class="text-center py-5">
                                    <i class="bi bi-inbox text-muted display-6"></i>
                                    <p class="text-muted mt-2">Não há registos pendentes de validação.</p>
                                </td>
                            </tr>
                        <% } else { %>
                            <% pendingList.forEach(function(item) { %>
                            <tr>
                                <td style="font-family: monospace; font-size: 0.85rem; color: #888;">
                                    #<%= item._id.toString().substring(18) %>
                                </td>
                                <td>
                                    <div class="fw-bold text-white"><%= item.name %></div>
                                    <% if(item.type === 'supermarket' || item.role === 'supermarket'){%>
                                        <small style="color:aquamarine">
                                            <i class=" bi bi-shop me-1"></i> Supermercado
                                        </small>
                                    <% } else { %>
                                        <small style="color:aquamarine">
                                            <i class="bi bi-bicycle me-1"></i> Estafeta
                                        </small>

                                    <% } %>                                
                                </td>
                                <td>
                                    <div style="color: #ddd;"><%= item.user.email %></div>
                                </td>
                                <td>
                                    <span class="loc-tag"><%= item.location %></span>
                                </td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <button class="btn btn-sm btn-outline-light border-secondary" onclick="openViewModal('<%= item._id %>')" title="Visualizar Detalhes">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        <button class="btn btn-sm btn-success px-3" style="font-weight: 600;" onclick="openApproveModal('<%= item._id %>')">
                                            Validar
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" onclick="openRejectModal('<%= item._id %>')">
                                            <i class="bi bi-trash"></i>
                                        </td>
                                    </div>
                                </td>
                            </tr>
                            <% }); %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/scripts/approvals.js"></script>
</body>
</html>
<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aprovações Pendentes - Marketplace</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/style/admin.css">
</head>
<body>

    <%- include('../partials/sidebar-admin') %>

    <main class="main-wrapper">
        <div class="mb-4">
            <h4 class="fw-bold">Validar Novos Registos</h4>
            <p class="text-muted">Lista completa de supermercados e estafetas à espera de aprovação.</p>
        </div>

        <div class="table-card">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>    
                            <th>ID (Supermercado)</th>
                            <th>Entidade</th>
                            <th>Contacto</th>
                            <th>Localidade</th>
                            <th class="text-end">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (pendingList.length === 0) { %>
                            <tr><td colspan="5" class="text-center py-4">Não há registos pendentes.</td></tr>
                        <% } else { %>
                            <% pendingList.forEach(function(item) { %>
                            <tr>
                                <td><strong><%= item._id %></strong></td>
                                <td><strong><%= item.name %></strong></td>
                                <td><%= item.user.email %></td>
                                <td><%= item.location ? item.location.address : '—' %></td>
                                <td class="text-end">
                                    <a href="/admin/supermarket/<%= item._id %>" class="btn btn-sm btn-light border shadow-sm me-1" title="Ver"><i class="bi bi-eye-fill text-primary"></i></a>
                                    <button class="btn btn-sm btn-light border shadow-sm me-1" onclick="openApproveModal('<%= item._id %>')" title="Validar"><i class="bi bi-check-lg text-success"></i></button>
                                    <button class="btn btn-sm btn-light border shadow-sm" onclick="openRejectModal('<%= item._id %>')" title="Rejeitar"><i class="bi bi-x-lg text-danger"></i></button>
                                </td>
                            </tr>
                            <% }); %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/scripts/approvals.js"></script>
</body>
</html>
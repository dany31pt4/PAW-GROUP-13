<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= market.name %> — Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/style/admin.css">
</head>
<body>

    <%- include('../partials/sidebar-admin') %>

    <main class="main-wrapper">

        <div class="d-flex align-items-center mb-4 gap-3">
            <% if (market.status === 'pending') { %>
                <a href="/admin/approvals" class="btn btn-light border shadow-sm" style="border-radius: 10px;">
                    <i class="bi bi-arrow-left me-1"></i> Voltar
                </a>
            <% } else { %>
                <a href="/admin/users" class="btn btn-light border shadow-sm" style="border-radius: 10px;">
                    <i class="bi bi-arrow-left me-1"></i> Voltar
                </a>
            <% } %>
            <div>
                <h4 id="market-name-title" class="fw-bold mb-0"><%= market.name %></h4>
                <p class="text-muted small mb-0">Detalhes do supermercado</p>
            </div>
        </div>

        <div class="row g-4">

            <div class="col-lg-5">
                <div class="table-card mt-0">

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h6 class="fw-bold mb-0"><i class="bi bi-shop text-primary me-2"></i>Informações</h6>
                        <%
                            const statusCls = { approved: 'bg-success', pending: 'bg-warning text-dark', rejected: 'bg-danger' };
                            const statusLabel = { approved: 'Aprovado', pending: 'Pendente', rejected: 'Rejeitado' };
                        %>
                        <span id="market-status-badge" class="badge <%= statusCls[market.status] || 'bg-secondary' %> px-3 py-2">
                            <%= statusLabel[market.status] || market.status %>
                        </span>
                    </div>

                    <div class="mb-3 p-3 rounded-3 bg-light border">
                        <div class="text-muted small mb-1"><i class="bi bi-shop me-1"></i>Nome</div>
                        <div class="fw-semibold"><%= market.name %></div>
                    </div>

                    <div class="mb-3 p-3 rounded-3 bg-light border">
                        <div class="text-muted small mb-1"><i class="bi bi-geo-alt me-1"></i>Localidade</div>
                        <div class="fw-semibold"><%= market.location || '—' %></div>
                    </div>

                    <% if (market.user) { %>
                    <div class="mb-3 p-3 rounded-3 bg-light border">
                        <div class="text-muted small mb-1"><i class="bi bi-envelope me-1"></i>Email de contacto</div>
                        <div class="fw-semibold"><%= market.user.email || '—' %></div>
                    </div>

                    <% if (market.user.phone) { %>
                    <div class="mb-3 p-3 rounded-3 bg-light border">
                        <div class="text-muted small mb-1"><i class="bi bi-telephone me-1"></i>Telefone</div>
                        <div class="fw-semibold"><%= market.user.phone %></div>
                    </div>
                    <% } %>
                    <% } %>

                    <% if (market.description) { %>
                    <div class="mb-3 p-3 rounded-3 bg-light border">
                        <div class="text-muted small mb-1"><i class="bi bi-text-left me-1"></i>Descrição</div>
                        <div><%= market.description %></div>
                    </div>
                    <% } %>

                    <% if (market.schedule) { %>
                    <div class="mb-3 p-3 rounded-3 bg-light border">
                        <div class="text-muted small mb-1"><i class="bi bi-clock me-1"></i>Horário</div>
                        <div class="fw-semibold"><%= market.schedule %></div>
                    </div>
                    <% } %>

                    <div class="mb-4 p-3 rounded-3 bg-light border">
                        <div class="text-muted small mb-1"><i class="bi bi-truck me-1"></i>Métodos de entrega</div>
                        <div class="d-flex gap-2 mt-1 flex-wrap">
                            <% if (market.deliveryMethods && market.deliveryMethods.includes('pickup')) { %>
                                <span class="badge bg-light text-dark border"><i class="bi bi-shop me-1"></i>Levantamento</span>
                            <% } %>
                            <% if (market.deliveryMethods && market.deliveryMethods.includes('courier')) { %>
                                <span class="badge bg-light text-dark border"><i class="bi bi-bicycle me-1"></i>Estafeta (<%= (market.deliveryCost || 0).toFixed(2) %>€)</span>
                            <% } %>
                            <% if (!market.deliveryMethods || market.deliveryMethods.length === 0) { %>
                                <span class="text-muted fst-italic">Não definido</span>
                            <% } %>
                        </div>
                    </div>

                    <!-- Ações -->
                    <div id="market-action-wrapper" class="d-flex gap-2 flex-wrap pt-3 border-top">
                        <% if (market.status === 'pending') { %>
                            <button class="btn btn-success px-4" onclick="approveMarket('<%= market._id %>')" style="border-radius: 10px;">
                                <i class="bi bi-check-lg me-2"></i>Validar
                            </button>
                            <button class="btn btn-outline-danger px-4" onclick="rejectMarket('<%= market._id %>')" style="border-radius: 10px;">
                                <i class="bi bi-x-lg me-2"></i>Rejeitar
                            </button>
                        <% } else { %>
                            <button class="btn btn-outline-danger px-4" onclick="deleteMarket('<%= market._id %>')" style="border-radius: 10px;">
                                <i class="bi bi-trash me-2"></i>Eliminar
                            </button>
                        <% } %>
                    </div>

                </div>
            </div>

            <div class="col-lg-7">
                <div class="table-card mt-0">
                    <h6 class="fw-bold mb-4"><i class="bi bi-box-seam text-primary me-2"></i>Estatísticas</h6>

                    <div class="row g-3 mb-4">
                        <div class="col-6">
                            <div class="p-3 rounded-3 bg-light border text-center">
                                <div class="text-muted small mb-1">Total Encomendas</div>
                                <div class="fs-3 fw-bold text-dark"><%= stats.totalOrders %></div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="p-3 rounded-3 bg-light border text-center">
                                <div class="text-muted small mb-1">Produtos</div>
                                <div class="fs-3 fw-bold text-dark"><%= stats.totalProducts %></div>
                            </div>
                        </div>
                    </div>

                    <% if (stats.recentOrders && stats.recentOrders.length > 0) { %>
                    <h6 class="fw-semibold text-muted mb-3" style="font-size: 0.82rem; letter-spacing: 0.5px;">ENCOMENDAS RECENTES</h6>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0" style="font-size: 13px;">
                            <thead class="table-light">
                                <tr>
                                    <th class="fw-semibold">Cliente</th>
                                    <th class="fw-semibold">Total</th>
                                    <th class="fw-semibold">Data</th>
                                    <th class="fw-semibold">Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% stats.recentOrders.forEach(o => { %>
                                <tr>
                                    <td><%= o.customer ? o.customer.name : 'N/A' %></td>
                                    <td class="fw-bold"><%= (o.total + o.deliveryCost).toFixed(2) %> €</td>
                                    <td class="text-muted"><%= new Date(o.createdAt).toLocaleDateString('pt-PT') %></td>
                                    <td>
                                        <%
                                            const sm = { pending: 'bg-warning-subtle text-warning', confirmed: 'bg-info-subtle text-info', delivered: 'bg-success-subtle text-success', cancelled: 'bg-danger-subtle text-danger' };
                                            const sl = { pending: 'Pendente', confirmed: 'Confirmada', delivered: 'Entregue', cancelled: 'Cancelada' };
                                        %>
                                        <span class="badge border <%= sm[o.status] || 'bg-light text-dark' %>">
                                            <%= sl[o.status] || o.status %>
                                        </span>
                                    </td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <% } else { %>
                        <p class="text-muted text-center py-3">Sem encomendas registadas.</p>
                    <% } %>
                </div>
            </div>

        </div>

    </main>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        async function approveMarket(id) {
            const confirmed = await Swal.fire({
                title: 'Aprovar Registo?',
                text: 'Este supermercado passará a estar ativo na plataforma.',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#198754',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Sim, validar!',
                cancelButtonText: 'Cancelar',
            });
            if (!confirmed.isConfirmed) return;

            Swal.fire({ title: 'A aprovar...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
            const res = await fetch(`/api/supermarkets/approve/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            });
            const data = await res.json();
            if (res.ok) {
                await Swal.fire('Aprovado!', 'O supermercado foi validado com sucesso.', 'success');
                window.location.href = '/admin/approvals';
            } else {
                Swal.fire('Erro!', data.message || 'Não foi possível aprovar.', 'error');
            }
        }

        async function rejectMarket(id) {
            const confirmed = await Swal.fire({
                title: 'Rejeitar Registo?',
                text: 'O supermercado não será aprovado.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Sim, rejeitar',
                cancelButtonText: 'Cancelar',
            });
            if (!confirmed.isConfirmed) return;

            Swal.fire({ title: 'A rejeitar...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
            const res = await fetch(`/api/supermarkets/reject/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            });
            const data = await res.json();
            if (res.ok) {
                await Swal.fire('Rejeitado!', 'O registo do supermercado foi rejeitado.', 'success');
                window.location.href = '/admin/approvals';
            } else {
                Swal.fire('Erro!', data.message || 'Não foi possível rejeitar.', 'error');
            }
        }

        async function deleteMarket(id) {
            const confirmed = await Swal.fire({
                title: 'Eliminar Supermercado?',
                text: 'Esta ação não pode ser revertida!',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Sim, eliminar!',
                cancelButtonText: 'Cancelar',
            });
            if (!confirmed.isConfirmed) return;

            const res = await fetch(`/api/supermarkets/delete/${id}`, {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            });
            const data = await res.json();
            if (res.ok && data.success) {
                await Swal.fire('Eliminado!', 'Supermercado eliminado com sucesso.', 'success');
                window.location.href = '/admin/users';
            } else {
                Swal.fire('Erro!', data.message || 'Não foi possível eliminar.', 'error');
            }
        }
    </script>

</body>
</html>

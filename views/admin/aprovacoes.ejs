<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aprovações Pendentes - Marketplace</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/stylesheets/admin.css">
</head>
<body>

    <aside class="sidebar">
        <div class="sidebar-brand">
            <i class="bi bi-box-seam" style="font-size:20px"></i>
            IPP Marketplace
        </div>

        <nav style="padding: 12px 0;">
            <a href="/admin/dashboard" class="nav-link-item <%= paginaAtiva === 'dashboard' ? 'active' : '' %>">
                <i class="bi bi-grid-1x2"></i> Painel geral
            </a>

            <a href="/admin/aprovacoes" class="nav-link-item <%= paginaAtiva === 'aprovacoes' ? 'active' : '' %>">
                <i class="bi bi-shop-window"></i> Aprovar lojas
                <% if (totalPendentes > 0) { %>
                    <span style="margin-left:auto; background:#e74c3c; color:#fff; border-radius:10px; font-size:11px; padding:1px 7px;">
                        <%= totalPendentes %>
                    </span>
                <% } %>
            </a>

            <a href="/admin/utilizadores" class="nav-link-item <%= paginaAtiva === 'utilizadores' ? 'active' : '' %>">
                <i class="bi bi-people"></i> Utilizadores
            </a>
            <a href="/admin/encomendas" class="nav-link-item <%= paginaAtiva === 'encomendas' ? 'active' : '' %>">
                <i class="bi bi-truck"></i> Encomendas
            </a>

            <div style="border-top: 1px solid rgba(255,255,255,0.08); margin: 16px 0;"></div>

            <a href="/auth/login" class="nav-link-item" style="color:#e74c3c;">
                <i class="bi bi-box-arrow-left"></i> Sair
            </a>
        </nav>
    </aside>

    <main class="main-wrapper">
        <div class="mb-4">
            <h4 class="fw-bold">Validar Novos Registos</h4>
            <p class="text-muted">Lista completa de supermercados e estafetas à espera de aprovação.</p>
        </div>

        <div class="table-card">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Entidade</th>
                            <th>Tipo</th>
                            <th>Contacto</th>
                            <th>Localidade</th>
                            <th class="text-end">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (listaPendentes.length === 0) { %>
                            <tr><td colspan="5" class="text-center py-4">Não há registos pendentes.</td></tr>
                        <% } else { %>
                            <% listaPendentes.forEach(function(item) { %>
                            <tr>
                                <td><strong><%= item.nome %></strong></td>
                                <td><span class="badge bg-secondary"><%= item.tipo %></span></td>
                                <td><%= item.email %></td>
                                <td><%= item.localidade %></td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-success">Validar</button>
                                    <button class="btn btn-sm btn-outline-danger">Rejeitar</button>
                                </td>
                            </tr>
                            <% }); %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Gestão de Categorias | Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="/style/admin.css" />
</head>
<body>
    <%- include('../partials/sidebar-admin') %>

    <main class="main-content">
        <header class="content-header mb-5">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="page-title" style="color: white; font-weight: 700;">Gestão de Categorias</h2>
                    <p style="color: #bbb;">Organize o marketplace criando e editando categorias de produtos.</p>
                </div>
                <button class="btn btn-success px-4 fw-bold" onclick="openAddCategoryModal()">
                    <i class="bi bi-plus-circle me-2"></i> Adicionar Categoria
                </button>
            </div>
        </header>

        <div class="custom-card">
            <div class="table-responsive">
                <table class="table custom-table align-middle">
                    <thead>
                        <tr>
                            <th class="border-0">Nome da Categoria</th>
                            <th class="border-0">Descrição</th>
                            <th class="border-0">Estado</th>
                            <th class="border-0 text-end">Ações</th>
                        </tr>
                    </thead>
                    <tbody id="categoryTableBody">
                        <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
                            <% categories.forEach(function(cat) { %>
                                <tr>
                                    <td class="text-white fw-bold"><%= cat.name %></td>
                                    <td class="text-muted" style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                        <%= cat.description || 'Sem descrição' %>
                                    </td>
                                    <td>
                                        <% if (cat.status === true || cat.status === 'active') { %>
                                            <span class="badge bg-success-subtle text-success border border-success-subtle">Ativa</span>
                                        <% } else { %>
                                            <span class="badge bg-secondary-subtle text-muted border border-secondary-subtle">Inativa</span>
                                        <% } %>
                                    </td>
                                    <td class="text-end">
                                        <div class="d-flex justify-content-end gap-2">
                                            <button class="btn btn-sm btn-outline-light border-secondary" 
                                                    onclick="openViewCategoryModal('<%= cat._id %>')" title="Visualizar">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-light border-secondary" 
                                                    onclick="openEditCategoryModal('<%= cat._id %>')" title="Editar">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" 
                                                    onclick="openRemoveCategoryModal('<%= cat._id %>')" title="Eliminar">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    <i class="bi bi-folder-x display-4 opacity-50 d-block mb-3"></i>
                                    Nenhuma categoria registada até ao momento.
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/scripts/categories.js"></script>
</body>
</html>
<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Categorias - Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="/style/admin.css" />
</head>
<body>
    <%- include('../partials/sidebar') %>

    <main class="main-wrapper">
        <div class="mb-4">
            <h4 class="fw-bold">Gestão de Categorias</h4>
            <p class="text-muted">Criação, edição e remoção de categorias.</p>
        </div>

        <div class="d-flex justify-content-end mb-3 mt-2">
            <button class="btn btn-primary"  onclick="openAddCategoryModal()">
                <i class="bi bi-plus-circle"></i> Adicionar Categoria
            </button>
        </div>

        <div class="table-card mt-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Nome</th>
                            <th>Estado</th>
                            <th class="text-end">Ações</th>
                        </tr>
                    </thead>
                    <tbody id="categoryTableBody">
                        <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
                            <% categories.forEach(function(cat) { %>
                                <tr>
                                    <td><strong><%= cat.name %></strong></td>
                                    <td>
                                        <% if (cat.status === true) { %>
                                            <span class="badge bg-success">Ativa</span>
                                        <% } else { %>
                                            <span class="badge bg-secondary">Inativa</span>
                                        <% } %>
                                    </td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-primary"  
                                                onclick="openViewCategoryModal('<%= cat._id %>')">
                                            Ver
                                        </button>

                                        <button class="btn btn-sm btn-outline-secondary"  
                                                onclick="openEditCategoryModal('<%= cat._id %>')">
                                            Editar
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger ms-1"  
                                                onclick="openRemoveCategoryModal('<%= cat._id %>')">
                                            Eliminar
                                        </button>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="4" class="text-center py-4 text-muted">Nenhuma categoria registada.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    
    
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/scripts/categories.js"></script>
</body>
</html>
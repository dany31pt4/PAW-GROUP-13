<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Encomendas & Estatísticas | Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/style/admin.css">
</head>
<body>

    <%- include('../partials/sidebar-admin') %>
    
    <main class="main-content">
        <header class="content-header mb-5">
            <div>
                <h2 class="page-title" style="color: white; font-weight: 700;">Gestão de Encomendas</h2>
                <p style="color: #bbb;">Análise de métricas de vendas e histórico de transações.</p>
            </div>
        </header>

        <div class="row g-4 mb-5">
            <div class="col-md-6">
                <div class="custom-card h-100">
                    <h6 class="fw-bold mb-4 text-white"><i class="bi bi-pie-chart-fill me-2 text-primary"></i>Vendas por Loja</h6>
                    <div style="height: 250px;">
                        <canvas id="chartLojas"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="custom-card h-100">
                    <h6 class="fw-bold mb-4 text-white"><i class="bi bi-bar-chart-line-fill me-2 text-primary"></i>Entregas por Estafeta</h6>
                    <div style="height: 250px;">
                        <canvas id="chartEstafetas"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="custom-card">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="m-0 text-white">Últimas Transações</h5>
                <span class="badge bg-dark border border-secondary text-muted">Tempo real</span>
            </div>
            <div class="table-responsive">
                <table class="table custom-table align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Cliente</th>
                            <th>Loja</th>
                            <th>Valor Total</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (listaEncomendas.length === 0) { %>
                            <tr><td colspan="5" class="text-center py-5 text-muted">Nenhuma transação registada até ao momento.</td></tr>
                        <% } else { %>
                            <% listaEncomendas.forEach(function(enc) { %>
                            <tr>
                                <td class="text-muted" style="font-size: 0.8rem;">#<%= enc.id.substring(18) %></td>
                                <td class="text-white fw-bold"><%= enc.client %></td>
                                <td><%= enc.market %></td>
                                <td class="text-white fw-bold"><%= enc.value %>€</td>
                                <td>
                                    <% if(enc.state === 'delivered' || enc.state === 'Entregue') { %>
                                        <span class="badge bg-success-subtle text-success border border-success-subtle">Entregue</span>
                                    <% } else if(enc.state === 'cancelled') { %>
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle">Cancelada</span>
                                    <% } else { %>
                                        <span class="badge bg-warning-subtle text-warning border border-warning-subtle">Processando</span>
                                    <% } %>
                                </td>
                            </tr>
                            <% }); %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        // Configurações Globais do Chart.js para Dark Mode
        Chart.defaults.color = '#80808a';
        Chart.defaults.borderColor = '#232326';

        // Gráfico de Lojas (Doughnut)
        const ctxLojas = document.getElementById('chartLojas');
        new Chart(ctxLojas, {
            type: 'doughnut',
            data: {
                labels: ['Pingo Doce', 'Continente', 'Lidl', 'Intermarché'],
                datasets: [{
                    data: [300, 50, 100, 80],
                    backgroundColor: ['#3498db', '#2ecc71', '#f1c40f', '#e74c3c'],
                    borderWidth: 0,
                    hoverOffset: 10
                }]
            },
            options: { 
                maintainAspectRatio: false,
                plugins: { 
                    legend: { position: 'bottom', labels: { padding: 20, usePointStyle: true } } 
                },
                cutout: '70%'
            }
        });

        // Gráfico de Estafetas (Barra Horizontal)
        const ctxEstafetas = document.getElementById('chartEstafetas');
        new Chart(ctxEstafetas, {
            type: 'bar',
            data: {
                labels: ['Ricardo', 'Ana', 'Bruno', 'Sofia'],
                datasets: [{
                    data: [12, 19, 10, 15],
                    backgroundColor: '#3498db',
                    borderRadius: 8,
                    barThickness: 15
                }]
            },
            options: { 
                indexAxis: 'y', 
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { grid: { display: false }, ticks: { display: true } },
                    y: { grid: { display: false } }
                }
            }
        });
    </script>
</body>
</html>
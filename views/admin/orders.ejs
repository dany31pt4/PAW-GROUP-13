<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Encomendas & Estatísticas - Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/style/admin.css">
</head>
<body>

    <%- include('../partials/sidebar-admin') %>

    <main class="main-wrapper"
        data-market-labels='<%- chartMarketLabels %>'
        data-market-data='<%- chartMarketData %>'
        data-courier-labels='<%- chartCourierLabels %>'
        data-courier-data='<%- chartCourierData %>'>

        <div class="mb-4">
            <h4 class="fw-bold">Gestão de Encomendas</h4>
            <p class="text-muted">Análise gráfica e listagem de todas as vendas.</p>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="table-card mt-0" style="height: 100%;">
                    <h6 class="fw-bold mb-3"><i class="bi bi-pie-chart-fill me-2"></i>Vendas por Loja</h6>
                    <div style="max-height: 250px; display: flex; justify-content: center;">
                        <canvas id="chartLojas"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="table-card mt-0" style="height: 100%;">
                    <h6 class="fw-bold mb-3"><i class="bi bi-bar-chart-line-fill me-2"></i>Entregas por Estafeta</h6>
                    <canvas id="chartEstafetas"></canvas>
                </div>
            </div>
        </div>

        <div class="table-card">
            <h6 class="fw-bold mb-3">Todas as Encomendas</h6>
            <div class="table-responsive">
                <table class="table table-hover align-middle" style="font-size:14px">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Cliente</th>
                            <th>Loja</th>
                            <th>Produtos</th>
                            <th>Total</th>
                            <th>Método</th>
                            <th>Data</th>
                            <th>Estado</th>
                            <th class="text-end">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (orders.length === 0) { %>
                            <tr>
                                <td colspan="9" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-3 opacity-50"></i>
                                    Não existem encomendas registadas.
                                </td>
                            </tr>
                        <% } else { %>
                            <% orders.forEach(order => { %>
                            <tr>
                                <td><span class="text-muted fw-bold" style="font-size:11px;"><%= order._id %></span></td>

                                <td>
                                    <strong><%= order.customer ? order.customer.name : 'N/A' %></strong><br>
                                    <small class="text-muted"><%= order.customer ? order.customer.email : '' %></small>
                                </td>

                                <td><%= order.supermarket ? order.supermarket.name : 'N/A' %></td>

                                <td>
                                    <ul class="list-unstyled mb-0 text-muted" style="font-size:12px;">
                                        <% order.products.forEach(item => { %>
                                            <li><span class="fw-bold text-dark"><%= item.quantity %>x</span> <%= item.product ? item.product.name : 'Indisponível' %></li>
                                        <% }) %>
                                    </ul>
                                </td>

                                <td><strong><%= (order.total + order.deliveryCost).toFixed(2) %>€</strong></td>

                                <td>
                                    <% if (order.deliveryMethod === 'pickup') { %>
                                        <span class="badge bg-light text-dark border"><i class="bi bi-shop me-1"></i> Levantamento</span>
                                    <% } else { %>
                                        <span class="badge bg-light text-dark border"><i class="bi bi-bicycle me-1"></i> Estafeta</span>
                                    <% } %>
                                </td>

                                <td class="text-muted" style="font-size:12px;">
                                    <%= new Date(order.createdAt).toLocaleDateString('pt-PT') %><br>
                                    <%= new Date(order.createdAt).toLocaleTimeString('pt-PT', {hour: '2-digit', minute:'2-digit'}) %>
                                </td>

                                <td>
                                    <%
                                        let badgeClass = '';
                                        let statusText = '';
                                        switch(order.status) {
                                            case 'pending':    badgeClass = 'bg-warning-subtle text-warning border-warning-subtle';     statusText = 'Pendente';       break;
                                            case 'confirmed':  badgeClass = 'bg-info-subtle text-info border-info-subtle';               statusText = 'Confirmada';     break;
                                            case 'preparing':         badgeClass = 'bg-primary-subtle text-primary border-primary-subtle';       statusText = 'Em Preparação';    break;
                                            case 'awaiting_courier':  badgeClass = 'bg-warning-subtle text-warning border-warning-subtle';       statusText = 'Aguarda Estafeta'; break;
                                            case 'delivering':        badgeClass = 'bg-secondary-subtle text-secondary border-secondary-subtle'; statusText = 'Com Estafeta';     break;
                                            case 'delivered':  badgeClass = 'bg-success-subtle text-success border-success-subtle';      statusText = 'Entregue';       break;
                                            case 'cancelled':  badgeClass = 'bg-danger-subtle text-danger border-danger-subtle';         statusText = 'Cancelada';      break;
                                            default:           badgeClass = 'bg-light text-dark'; statusText = order.status;
                                        }
                                    %>
                                    <span class="badge border <%= badgeClass %> px-2 py-1"><%= statusText %></span>
                                </td>
                                <td class="text-end">
                                    <a href="/admin/order/<%= order._id %>" class="btn btn-sm btn-light border shadow-sm" title="Ver detalhes"><i class="bi bi-eye-fill text-primary"></i></a>
                                </td>
                            </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="/scripts/admin-orders.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestão de Produtos - Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/style/admin.css">
</head>
<body>

    <%- include('../partials/sidebar-admin') %>

    <main class="main-wrapper">

        <div class="mb-4">
            <h4 class="fw-bold">Gestão de Produtos</h4>
            <p class="text-muted">Consulta e modera todos os produtos da plataforma.</p>
        </div>

        <div class="table-card">
            <div class="table-responsive">
                <table class="table table-hover align-middle" style="font-size:14px">
                    <thead>
                        <tr class="text-muted" style="font-size:12px">
                            <th>Nome</th>
                            <th>Supermercado</th>
                            <th>Categoria</th>
                            <th>Preço</th>
                            <th>Stock</th>
                            <th>Estado</th>
                            <th class="text-end">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (products.length === 0) { %>
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-3 opacity-50"></i>
                                    Nenhum produto registado na plataforma.
                                </td>
                            </tr>
                        <% } else { %>
                            <% products.forEach(function(p) { %>
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <% if (p.image) { %>
                                            <img src="<%= p.image %>" class="rounded-2" style="width:36px; height:36px; object-fit:cover; border:1px solid #eee;">
                                        <% } else { %>
                                            <div class="rounded-2 bg-light d-flex align-items-center justify-content-center" style="width:36px; height:36px; border:1px solid #eee;">
                                                <i class="bi bi-image text-muted" style="font-size:14px;"></i>
                                            </div>
                                        <% } %>
                                        <strong><%= p.name %></strong>
                                    </div>
                                </td>
                                <td><%= p.supermarket ? p.supermarket.name : 'N/A' %></td>
                                <td>
                                    <span class="badge bg-light text-dark border px-2 py-1">
                                        <%= p.category ? p.category.name : 'Sem categoria' %>
                                    </span>
                                </td>
                                <td><strong><%= p.price.toFixed(2) %> €</strong></td>
                                <td>
                                    <% if (p.stock <= 5) { %>
                                        <span class="text-danger fw-bold"><i class="bi bi-exclamation-circle me-1"></i><%= p.stock %></span>
                                    <% } else { %>
                                        <span class="text-muted"><%= p.stock %> unid.</span>
                                    <% } %>
                                </td>
                                <td>
                                    <% if (p.isActive) { %>
                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1">Ativo</span>
                                    <% } else { %>
                                        <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-2 py-1">Inativo</span>
                                    <% } %>
                                </td>
                                <td class="text-end">
                                    <a href="/admin/product/<%= p._id %>" class="btn btn-sm btn-light border shadow-sm me-1" title="Ver detalhes">
                                        <i class="bi bi-eye-fill text-primary"></i>
                                    </a>
                                    <button class="btn btn-sm btn-light border shadow-sm" onclick="toggleAdminProduct('<%= p._id %>', <%= p.isActive %>)" title="<%= p.isActive ? 'Desativar' : 'Ativar' %>">
                                        <% if (p.isActive) { %>
                                            <i class="bi bi-toggle-on text-success fs-6"></i>
                                        <% } else { %>
                                            <i class="bi bi-toggle-off text-secondary fs-6"></i>
                                        <% } %>
                                    </button>
                                </td>
                            </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

    </main>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/scripts/admin-products.js"></script>
</body>
</html>

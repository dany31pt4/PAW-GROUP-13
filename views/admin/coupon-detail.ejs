<!DOCTYPE html>
<html lang="pt">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= coupon.code %> — Admin
    </title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/style/admin.css">
</head>

<body>

    <%- include('../partials/sidebar-admin', { activePage: 'coupons' }) %>

        <main class="main-wrapper">

            <div class="d-flex align-items-center mb-4 gap-3">
                <a href="/admin/coupons" class="btn btn-light border shadow-sm" style="border-radius: 10px;">
                    <i class="bi bi-arrow-left me-1"></i> Voltar
                </a>
                <div>
                    <h4 class="fw-bold mb-0"><i class="bi bi-ticket-perforated me-2"></i>
                        <%= coupon.code %>
                    </h4>
                    <p class="text-muted small mb-0">Detalhes do cupão</p>
                </div>
            </div>

            <div class="row g-4">

                <div class="col-lg-5">
                    <div class="table-card mt-0">

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h6 class="fw-bold mb-0"><i
                                    class="bi bi-ticket-perforated text-primary me-2"></i>Informações</h6>
                            <% if (coupon.active) { %>
                                <span class="badge bg-success px-3 py-2">Ativo</span>
                                <% } else { %>
                                    <span class="badge bg-secondary px-3 py-2">Inativo</span>
                                    <% } %>
                        </div>

                        <div class="mb-3 p-3 rounded-3 bg-light border">
                            <div class="text-muted small mb-1"><i class="bi bi-upc me-1"></i>Código</div>
                            <div class="fw-semibold"><code style="font-size:1rem;"><%= coupon.code %></code></div>
                        </div>

                        <div class="mb-3 p-3 rounded-3 bg-light border">
                            <div class="text-muted small mb-1"><i class="bi bi-percent me-1"></i>Desconto</div>
                            <div class="fw-semibold">
                                <%= coupon.discountValue %>%
                            </div>
                        </div>

                        <div class="mb-3 p-3 rounded-3 bg-light border">
                            <div class="text-muted small mb-1"><i class="bi bi-shop me-1"></i>Supermercado</div>
                            <div class="fw-semibold">
                                <% if (coupon.supermarket) { %>
                                    <a href="/admin/supermarket/<%= coupon.supermarket._id %>">
                                        <%= coupon.supermarket.name %>
                                    </a>
                                    <% } else { %>
                                        —
                                        <% } %>
                            </div>
                        </div>

                        <div class="mb-3 p-3 rounded-3 bg-light border">
                            <div class="text-muted small mb-1"><i class="bi bi-calendar-event me-1"></i>Validade</div>
                            <div class="fw-semibold">
                                <% if (coupon.expiresAt) { %>
                                    <%= new Date(coupon.expiresAt).toLocaleDateString('pt-PT') %>
                                        <% } else { %>
                                            Sem validade
                                            <% } %>
                            </div>
                        </div>

                        <div class="mb-3 p-3 rounded-3 bg-light border">
                            <div class="text-muted small mb-1"><i class="bi bi-arrow-repeat me-1"></i>Usos</div>
                            <div class="fw-semibold">
                                <% if (coupon.maxUses> 0) { %>
                                    <%= coupon.usedCount %> / <%= coupon.maxUses %>
                                            <% } else { %>
                                                <%= coupon.usedCount %> / ∞ (ilimitado)
                                                    <% } %>
                            </div>
                        </div>

                        <div class="mb-4 p-3 rounded-3 bg-light border">
                            <div class="text-muted small mb-1"><i class="bi bi-clock me-1"></i>Criado em</div>
                            <div class="fw-semibold">
                                <%= new Date(coupon.createdAt).toLocaleDateString('pt-PT') %>
                            </div>
                        </div>

                        <div class="d-flex gap-2 flex-wrap pt-3 border-top">
                            <button class="btn btn-primary px-4"
                                onclick="openEditModal(`<%- coupon._id %>`, `<%- coupon.code %>`, `<%- coupon.discountValue %>`, `<%- coupon.expiresAt ? new Date(coupon.expiresAt).toISOString().slice(0,10) : '' %>`, `<%- coupon.maxUses %>`)"
                                style="border-radius: 10px;">
                                <i class="bi bi-pencil me-2"></i>Editar
                            </button>
                            <button class="btn btn-outline-<%= coupon.active ? 'warning' : 'success' %> px-4"
                                onclick="toggleCoupon('<%= coupon._id %>')" style="border-radius: 10px;">
                                <% if (coupon.active) { %>
                                    <i class="bi bi-pause-circle me-2"></i>Desativar
                                    <% } else { %>
                                        <i class="bi bi-play-circle me-2"></i>Ativar
                                        <% } %>
                            </button>
                            <button class="btn btn-outline-danger px-4"
                                onclick="deleteCoupon('<%= coupon._id %>','<%= coupon.code %>')"
                                style="border-radius: 10px;">
                                <i class="bi bi-trash me-2"></i>Eliminar
                            </button>
                        </div>

                    </div>
                </div>

            </div>

        </main>

        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        <script>
            function openEditModal(id, code, discountValue, expiresAt, maxUses) {
                Swal.fire({
                    title: "Editar Cupão",
                    html: `
                    <div class="text-start mt-2">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Código <span class="text-danger">*</span></label>
                            <input type="text" id="ec-code" class="form-control text-uppercase" value="${code}">
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Desconto (%) <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input type="number" id="ec-value" class="form-control" value="${discountValue}" min="0.01" max="100" step="0.01">
                                <span class="input-group-text">%</span>
                            </div>
                        </div>
                        <div class="row g-3">
                            <div class="col-6">
                                <label class="form-label fw-bold">Data de Validade</label>
                                <input type="date" id="ec-expires" class="form-control" value="${expiresAt}">
                                <div class="form-text">Em branco = sem validade.</div>
                            </div>
                            <div class="col-6">
                                <label class="form-label fw-bold">Usos Máximos</label>
                                <input type="number" id="ec-maxuses" class="form-control" value="${maxUses}" placeholder="0 = ilimitado" min="0">
                            </div>
                        </div>
                    </div>
                `,
                    showCancelButton: true,
                    confirmButtonText: "Guardar",
                    cancelButtonText: "Cancelar",
                    confirmButtonColor: "#0d6efd",
                    preConfirm: () => {
                        const code = document.getElementById("ec-code").value.trim();
                        const discountValue = document.getElementById("ec-value").value;
                        if (!code || !discountValue) {
                            Swal.showValidationMessage("Código e valor são obrigatórios.");
                            return false;
                        }
                        return {
                            code,
                            discountValue,
                            expiresAt: document.getElementById("ec-expires").value || null,
                            maxUses: document.getElementById("ec-maxuses").value || 0,
                        };
                    },
                }).then(async (result) => {
                    if (!result.isConfirmed) return;
                    Swal.fire({ title: "A guardar...", allowOutsideClick: false, didOpen: () => Swal.showLoading() });
                    try {
                        const res = await fetch("/api/coupons/update/" + id, {
                            method: "PUT",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify(result.value),
                        });
                        const data = await res.json();
                        if (res.ok) {
                            await Swal.fire("Guardado!", "Cupão atualizado com sucesso.", "success");
                            window.location.reload();
                        } else {
                            Swal.fire("Erro", data.message || "Não foi possível atualizar.", "error");
                        }
                    } catch {
                        Swal.fire("Erro", "Erro de conexão ao servidor.", "error");
                    }
                });
            }

            async function toggleCoupon(id) {
                try {
                    const res = await fetch("/api/coupons/toggle/" + id, { method: "PUT" });
                    if (res.ok) {
                        window.location.reload();
                    } else {
                        Swal.fire("Erro", "Não foi possível alterar o estado.", "error");
                    }
                } catch {
                    Swal.fire("Erro", "Erro de conexão ao servidor.", "error");
                }
            }

            async function deleteCoupon(id, code) {
                const confirmed = await Swal.fire({
                    title: 'Eliminar cupão "' + code + '"?',
                    text: "Esta ação não pode ser revertida.",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonColor: "#dc3545",
                    confirmButtonText: "Eliminar",
                    cancelButtonText: "Cancelar",
                });
                if (!confirmed.isConfirmed) return;

                Swal.fire({ title: "A eliminar...", allowOutsideClick: false, didOpen: () => Swal.showLoading() });
                try {
                    const res = await fetch("/api/coupons/delete/" + id, { method: "DELETE" });
                    if (res.ok) {
                        await Swal.fire("Eliminado!", "Cupão removido com sucesso.", "success");
                        window.location.href = "/admin/coupons";
                    } else {
                        Swal.fire("Erro", "Não foi possível eliminar.", "error");
                    }
                } catch {
                    Swal.fire("Erro", "Erro de conexão ao servidor.", "error");
                }
            }
        </script>

</body>

</html>
<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Painel de Administração - Marketplace</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    
    <link rel="stylesheet" href="/style/admin.css">
</head>
<body>

    <%- include('../partials/sidebar-admin') %>

    <main class="main-wrapper">
        
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h4 style="font-weight:700; color:#2c3e50; margin:0">Painel de administração</h4>
                <small class="text-muted">Olá, <strong><%= adminName %></strong></small>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-6 col-md-3">
                <div class="stat-card blue">
                    <div class="stat-label">Encomendas</div>
                    <div class="stat-val" style="color:#3498db"><%= totalOrders %></div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card green">
                    <div class="stat-label">Supermercados ativos</div>
                    <div class="stat-val" style="color:#2ecc71"><%= totalMarkets %></div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card orange">
                    <div class="stat-label">Pendentes aprovação</div>
                    <div class="stat-val" style="color:#f39c12"><%= allPending %></div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card red">
                    <div class="stat-label">Clientes</div>
                    <div class="stat-val" style="color:#e74c3c"><%= totalCustomers %></div>
                </div>
            </div>
        </div>

        <div class="table-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 style="font-weight:700; margin:0">Aprovação de novos registos</h6>
                <a href="/admin/approvals" class="btn btn-sm btn-outline-primary">Ver todos</a>
            </div>

            <div class="table-responsive">
                <% if (pendingMarkets.length === 0) { %>
                    <p class="text-muted" style="font-size:14px; padding: 20px 0;">Nenhum registo pendente de aprovação.</p>
                <% } else { %>
                    <table class="table table-hover align-middle" style="font-size:14px">
                        <thead>
                            <tr class="text-muted" style="font-size:12px">
                                <th>Nome da loja</th>
                                <th>Responsável</th>
                                <th>Localidade</th>
                                <th class="text-end">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% pendingMarkets.forEach(function(s) { %>
                            <tr>
                                <td><strong><%= s.name %></strong></td>
                                <td class="text-muted"><%= s.email %></td>
                                <td><%= s.location %></td>
                                <td class="text-end">
                                    <button type="button" onclick="PUT('../api/supermarkets/approve/<%= s._id %>')" class="btn btn-sm btn-success px-3">Validar</button>
                                    <button type="button" onclick="PUT('/api/supermarkets/reject/<%= s._id %>')" class="btn btn-sm btn-outline-danger px-3 ms-1">Rejeitar</button>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                <% } %>
            </div> </div>

    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function PUT(url) {
            fetch(url, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(response => {
                if (response.ok) {
                    window.location.reload();
                } else {
                    alert('Ocorreu um erro ao processar o pedido.');
                }
            })
            .catch(error => {
                console.error('Erro:', error);
                alert('Erro de conexão.');
            });
        }
    </script>
</body>
</html>
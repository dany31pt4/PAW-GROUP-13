<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Painel de Administração | Marketplace</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    
    <link rel="stylesheet" href="/style/admin.css">
</head>
<body>

    <%- include('../partials/sidebar-admin') %>

    <main class="main-content">
        <header class="content-header mb-5">
            <div>
                <h2 class="page-title" style="font-weight: 700; color: #fff;">Painel Geral</h2>
                <p style="color:rgb(255, 254, 252)">Bem-vindo de volta, <span class="text-white fw-semibold"><%= adminName %></span></p>
            </div>
        </header>

        <div class="row g-4 mb-5">
            <div class="col-md-3">
                <div class="stat-card">
                    <div class="icon-shape blue"><i class="bi bi-truck"></i></div>
                    <div class="stat-content">
                        <span class="stat-label">Encomendas</span>
                        <h3 class="stat-value"><%= totalOrders %></h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card">
                    <div class="icon-shape green"><i class="bi bi-shop"></i></div>
                    <div class="stat-content">
                        <span class="stat-label">Lojas Ativas</span>
                        <h3 class="stat-value"><%= totalMarkets %></h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card">
                    <div class="icon-shape orange"><i class="bi bi-hourglass-split"></i></div>
                    <div class="stat-content">
                        <span class="stat-label">Pendentes</span>
                        <h3 class="stat-value"><%= allPending %></h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-card">
                    <div class="icon-shape purple"><i class="bi bi-people"></i></div>
                    <div class="stat-content">
                        <span class="stat-label">Clientes</span>
                        <h3 class="stat-value"><%= totalCustomers %></h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="custom-card">
                    <div class="card-header-custom d-flex justify-content-between align-items-center mb-4">
                        <h5 class="m-0 text-white">Aprovações Prioritárias</h5>
                        <a href="/admin/approvals" class="btn btn-sm btn-outline-secondary border-0">Ver todas</a>
                    </div>
                    
                    <div class="table-responsive">
                        <% if (pendingMarkets.length === 0) { %>
                            <div class="text-center py-5">
                                <i class="bi bi-check-circle text-success opacity-50 display-6"></i>
                                <p class="text-muted mt-3">Nenhum registo pendente de aprovação.</p>
                            </div>
                        <% } else { %>
                            <table class="table custom-table align-middle">
                                <thead>
                                    <tr>
                                        <th class="border-0">Loja</th>
                                        <th class="border-0">Localidade</th>
                                        <th class="border-0 text-end">Ação</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% pendingMarkets.slice(0, 5).forEach(function(s) { %>
                                        <tr>
                                            <td>
                                                <div class="fw-bold text-white"><%= s.name %></div>
                                                <small class="text-muted"><%= s.email %></small>
                                            </td>
                                            <td>
                                                <span class="loc-tag"><%= s.location %></span>
                                            </td>
                                            <td class="text-end">
                                                <button type="button" onclick="PUT('/api/supermarkets/approve/<%= s._id %>')" class="btn-action approve">Validar</button>
                                            </td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        <% } %>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="custom-card h-100">
                    <div class="card-header-custom mb-4">
                        <h5 class="m-0 text-white">Resumo do Sistema</h5>
                    </div>
                    <div class="summary-list">
                        <div class="summary-item d-flex justify-content-between py-3 border-bottom border-dark">
                            <span style="color:rgb(255, 254, 252)">Total Utilizadores</span>
                            <span class="text-white fw-bold"><%= totalCustomers + totalMarkets %></span>
                        </div>
                        <div class="summary-item d-flex justify-content-between py-3 border-bottom border-dark">
                            <span style="color:rgb(255, 254, 252)">Estado do Servidor</span>
                            <span class="badge bg-success-subtle text-success">Online</span>
                        </div>
                        <div class="summary-item d-flex justify-content-between py-3">
                            <span style="color:rgb(255, 254, 252)">Categorias</span>
                            <span class="text-white">12</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function PUT(url) {
            fetch(url, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' }
            })
            .then(response => {
                if (response.ok) {
                    window.location.reload();
                } else {
                    alert('Erro ao processar o pedido.');
                }
            })
            .catch(error => {
                console.error('Erro:', error);
                alert('Erro de conexão.');
            });
        }
    </script>
</body>
</html>
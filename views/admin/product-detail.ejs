<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= product.name %> — Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/style/admin.css">
</head>
<body>

    <%- include('../partials/sidebar-admin') %>

    <main class="main-wrapper">

        <div class="d-flex align-items-center mb-4 gap-3">
            <a href="/admin/products" class="btn btn-light border shadow-sm" style="border-radius: 10px;">
                <i class="bi bi-arrow-left me-1"></i> Voltar
            </a>
            <div>
                <h4 class="fw-bold mb-0"><%= product.name %></h4>
                <p class="text-muted small mb-0">Detalhes do produto</p>
            </div>
        </div>

        <div class="row g-4">

            <div class="col-lg-4">
                <div class="table-card mt-0 text-center">
                    <% if (product.image) { %>
                        <img src="<%= product.image %>" class="rounded-3 mb-3 shadow-sm" style="width:100%; max-height:220px; object-fit:cover;">
                    <% } else { %>
                        <div class="rounded-3 bg-light d-flex align-items-center justify-content-center mb-3" style="height:180px;">
                            <i class="bi bi-image text-muted" style="font-size:3rem;"></i>
                        </div>
                    <% } %>

                    <% if (product.isActive) { %>
                        <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 fs-6">Ativo</span>
                    <% } else { %>
                        <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-3 py-2 fs-6">Inativo</span>
                    <% } %>

                    <div class="mt-4">
                        <button class="btn btn-outline-secondary w-100" onclick="toggleAdminProduct('<%= product._id %>', <%= product.isActive %>)">
                            <% if (product.isActive) { %>
                                <i class="bi bi-toggle-on me-2 text-success"></i>Desativar produto
                            <% } else { %>
                                <i class="bi bi-toggle-off me-2"></i>Ativar produto
                            <% } %>
                        </button>
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="table-card mt-0">
                    <h6 class="fw-bold mb-4"><i class="bi bi-box-seam text-primary me-2"></i>Informações</h6>

                    <div class="mb-3 p-3 rounded-3 bg-light border">
                        <div class="text-muted small mb-1">Nome</div>
                        <div class="fw-semibold"><%= product.name %></div>
                    </div>

                    <div class="mb-3 p-3 rounded-3 bg-light border">
                        <div class="text-muted small mb-1">Descrição</div>
                        <div class="<%= product.description ? '' : 'text-muted fst-italic' %>">
                            <%= product.description || 'Sem descrição' %>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-sm-4">
                            <div class="p-3 rounded-3 bg-light border">
                                <div class="text-muted small mb-1">Preço</div>
                                <div class="fw-bold fs-5"><%= product.price.toFixed(2) %> €</div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="p-3 rounded-3 bg-light border">
                                <div class="text-muted small mb-1">Stock</div>
                                <% if (product.stock <= 5) { %>
                                    <div class="fw-bold fs-5 text-danger"><%= product.stock %> unid.</div>
                                <% } else { %>
                                    <div class="fw-bold fs-5"><%= product.stock %> unid.</div>
                                <% } %>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="p-3 rounded-3 bg-light border">
                                <div class="text-muted small mb-1">Categoria</div>
                                <div class="fw-semibold"><%= product.category ? product.category.name : 'Sem categoria' %></div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3 p-3 rounded-3 bg-light border">
                        <div class="text-muted small mb-1">Supermercado</div>
                        <div class="fw-semibold">
                            <% if (product.supermarket) { %>
                                <a href="/admin/supermarket/<%= product.supermarket._id %>" class="text-decoration-none">
                                    <%= product.supermarket.name %>
                                </a>
                            <% } else { %>
                                N/A
                            <% } %>
                        </div>
                    </div>

                    <div class="p-3 rounded-3 bg-light border">
                        <div class="text-muted small mb-1">Adicionado em</div>
                        <div class="fw-semibold">
                            <%= new Date(product.createdAt).toLocaleDateString('pt-PT', { day: '2-digit', month: 'long', year: 'numeric' }) %>
                        </div>
                    </div>
                </div>
            </div>

        </div>

    </main>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/scripts/admin-products.js"></script>
</body>
</html>

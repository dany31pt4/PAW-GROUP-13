<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>As Minhas Encomendas — Marketplace</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/style/admin.css">
</head>
<body>
    <%- include('../partials/sidebar-customer', { activePage: 'orders' }) %>
    <main class="main-wrapper">
        <div class="mb-4">
            <h4 class="fw-bold">As Minhas Encomendas</h4>
            <p class="text-muted">Histórico de todas as tuas encomendas.</p>
        </div>

        <div class="table-card">
            <% if (orders.length === 0) { %>
                <p class="text-muted text-center py-4">Ainda não fizeste nenhuma encomenda.</p>
            <% } else { %>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Loja</th>
                            <th>Data</th>
                            <th>Total</th>
                            <th>Entrega</th>
                            <th>Estado</th>
                            <th class="text-end">Ação</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% orders.forEach(function(o) {
                            const statusMap = {
                                pending: { label: 'Pendente', cls: 'bg-warning text-dark' },
                                confirmed: { label: 'Confirmada', cls: 'bg-info text-dark' },
                                preparing: { label: 'Em Preparação', cls: 'bg-primary' },
                                awaiting_courier: { label: 'A Aguardar Estafeta', cls: 'bg-secondary' },
                                delivering: { label: 'A Caminho', cls: 'bg-primary' },
                                delivered: { label: 'Entregue', cls: 'bg-success' },
                                cancelled: { label: 'Cancelada', cls: 'bg-danger' }
                            };
                            const s = statusMap[o.status] || { label: o.status, cls: 'bg-secondary' };
                            const deliveryLabel = o.deliveryMethod === 'courier' ? 'Domicílio' : 'Levantamento';
                        %>
                        <tr>
                            <td><strong><%= o.supermarket ? o.supermarket.name : '—' %></strong></td>
                            <td class="text-muted small"><%= new Date(o.createdAt).toLocaleDateString('pt-PT') %></td>
                            <td class="fw-semibold"><%= (o.total + o.deliveryCost).toFixed(2) %>€</td>
                            <td class="small"><%= deliveryLabel %></td>
                            <td><span class="badge <%= s.cls %>"><%= s.label %></span></td>
                            <td class="text-end">
                                <a href="/customer/order/<%= o._id %>" class="btn btn-sm btn-light border shadow-sm" title="Ver">
                                    <i class="bi bi-eye-fill text-primary"></i>
                                </a>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
            <% } %>
        </div>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

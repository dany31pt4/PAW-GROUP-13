<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Encomenda — Marketplace</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/style/admin.css">
</head>
<body>
    <%- include('../partials/sidebar-customer', { activePage: 'orders' }) %>
    <main class="main-wrapper">
        <%
            const statusMap = {
                pending: { label: 'Pendente', cls: 'bg-warning text-dark' },
                confirmed: { label: 'Confirmada', cls: 'bg-info text-dark' },
                preparing: { label: 'Em Preparação', cls: 'bg-primary' },
                awaiting_courier: { label: 'A Aguardar Estafeta', cls: 'bg-secondary' },
                delivering: { label: 'A Caminho', cls: 'bg-primary' },
                delivered: { label: 'Entregue', cls: 'bg-success' },
                cancelled: { label: 'Cancelada', cls: 'bg-danger' }
            };
            const s = statusMap[order.status] || { label: order.status, cls: 'bg-secondary' };
        %>

        <div class="d-flex align-items-center mb-4 gap-3">
            <a href="/customer/orders" class="btn btn-light border shadow-sm" style="border-radius:10px;">
                <i class="bi bi-arrow-left me-1"></i> Voltar
            </a>
            <div>
                <h4 class="fw-bold mb-0">Encomenda</h4>
                <p class="text-muted small mb-0"><%= new Date(order.createdAt).toLocaleDateString('pt-PT') %> · <%= order.supermarket ? order.supermarket.name : '—' %></p>
            </div>
            <span class="badge <%= s.cls %> px-3 py-2 ms-auto"><%= s.label %></span>
        </div>

        <div class="row g-4">
            <div class="col-lg-7">
                <div class="table-card mt-0">
                    <h6 class="fw-bold mb-3"><i class="bi bi-box-seam text-primary me-2"></i>Produtos</h6>
                    <table class="table align-middle mb-0" style="font-size:13px;">
                        <thead class="table-light">
                            <tr><th>Produto</th><th>Qtd</th><th class="text-end">Preço</th></tr>
                        </thead>
                        <tbody>
                            <% order.products.forEach(function(item) { %>
                            <tr>
                                <td><%= item.product ? item.product.name : '—' %></td>
                                <td><%= item.quantity %></td>
                                <td class="text-end"><%= (item.unitPrice * item.quantity).toFixed(2) %>€</td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>

                    <hr>
                    <div class="d-flex justify-content-between small mb-1">
                        <span class="text-muted">Subtotal</span>
                        <span><%= (order.total + (order.discount || 0)).toFixed(2) %>€</span>
                    </div>
                    <% if (order.discount && order.discount > 0) { %>
                    <div class="d-flex justify-content-between small mb-1">
                        <span class="text-success"><i class="bi bi-ticket-perforated me-1"></i>Desconto<% if (order.coupon) { %> (<%= order.coupon.code %>)<% } %></span>
                        <span class="text-success fw-semibold">−<%= order.discount.toFixed(2) %>€</span>
                    </div>
                    <% } %>
                    <% if (order.deliveryCost > 0) { %>
                    <div class="d-flex justify-content-between small mb-1">
                        <span class="text-muted">Taxa de entrega</span>
                        <span><%= order.deliveryCost.toFixed(2) %>€</span>
                    </div>
                    <% } %>
                    <div class="d-flex justify-content-between fw-bold mt-1">
                        <span>Total</span>
                        <span><%= (order.total + order.deliveryCost).toFixed(2) %>€</span>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="table-card mt-0">
                    <h6 class="fw-bold mb-3"><i class="bi bi-info-circle text-primary me-2"></i>Detalhes</h6>

                    <div class="mb-3 p-3 rounded-3 bg-light border">
                        <div class="text-muted small mb-1">Loja</div>
                        <div class="fw-semibold"><%= order.supermarket ? order.supermarket.name : '—' %></div>
                    </div>
                    <div class="mb-3 p-3 rounded-3 bg-light border">
                        <div class="text-muted small mb-1">Método de Entrega</div>
                        <div class="fw-semibold"><%= order.deliveryMethod === 'courier' ? 'Entrega ao Domicílio' : 'Levantamento em Loja' %></div>
                    </div>
                    <% if (order.deliveryAddress) { %>
                    <div class="mb-3 p-3 rounded-3 bg-light border">
                        <div class="text-muted small mb-1">Morada de Entrega</div>
                        <div class="fw-semibold"><%= order.deliveryAddress %></div>
                    </div>
                    <% } %>
                    <% if (order.courier) { %>
                    <div class="mb-3 p-3 rounded-3 bg-light border">
                        <div class="text-muted small mb-1">Estafeta</div>
                        <div class="fw-semibold"><%= order.courier.name %></div>
                    </div>
                    <% } %>

                    <% if (canCancel) { %>
                    <div class="pt-3 border-top">
                        <button class="btn btn-outline-danger w-100" onclick="cancelOrder('<%= order._id %>')">
                            <i class="bi bi-x-circle me-2"></i>Cancelar Encomenda
                        </button>
                        <% if (order.status === 'confirmed') { %>
                        <p class="text-muted small mt-2 mb-0"><i class="bi bi-clock me-1"></i>Só é possível cancelar nos primeiros 5 minutos após confirmação.</p>
                        <% } %>
                    </div>
                    <% } %>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        async function cancelOrder(id) {
            const confirmed = await Swal.fire({
                title: 'Cancelar encomenda?',
                text: 'Esta ação não pode ser revertida.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                confirmButtonText: 'Sim, cancelar',
                cancelButtonText: 'Não',
            });
            if (!confirmed.isConfirmed) return;
            Swal.fire({ title: 'A cancelar...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
            try {
                const res = await fetch('/api/orders/cancel/' + id, { method: 'PUT' });
                const data = await res.json();
                if (res.ok) {
                    await Swal.fire('Cancelada!', 'A tua encomenda foi cancelada.', 'success');
                    window.location.reload();
                } else {
                    Swal.fire('Erro', data.message || 'Não foi possível cancelar.', 'error');
                }
            } catch {
                Swal.fire('Erro', 'Erro de conexão.', 'error');
            }
        }
    </script>
</body>
</html>

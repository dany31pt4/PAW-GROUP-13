<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — Marketplace Local</title>
  
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  
  <link rel="stylesheet" href="/style/auth.css">
</head>
<body>

  <div class="auth-card shadow-lg">
    
    <div class="brand-title">Marketplace Local</div>
    <div class="brand-subtitle">Portal de Administração</div>

    <% if (locals.erro) { %>
      <div class="alert alert-danger bg-danger bg-opacity-10 text-danger border-0 small rounded-3 mb-4">
        <i class="bi bi-exclamation-circle-fill me-2"></i> <%= locals.erro %>
      </div>
    <% } %>

    <form action="/auth/login" method="POST">
      <div class="mb-3">
        <label for="email" class="form-label-custom">Email</label>
        <input 
          type="email" 
          class="form-control-custom" 
          id="email" 
          name="email" 
          placeholder="exemplo@ipp.pt" 
          required>
      </div>

      <div class="mb-4">
        <label for="password" class="form-label-custom">Password</label>
        <input 
          type="password" 
          class="form-control-custom" 
          id="password" 
          name="password" 
          placeholder="••••••••" 
          required>
      </div>

      <button type="submit" class="btn-submit btn-super">
        Entrar
      </button>
    </form>

    <div class="hr-custom"></div>

    <div class="text-center">
      <span class="text-muted small">Novo parceiro?</span>
      <a href="/auth/register" class="footer-link fw-bold">Criar conta agora</a>
    </div>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
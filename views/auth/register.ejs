<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Registo — Marketplace</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<style>
  .nav-pills .nav-link.active { background-color: #0d6efd; }
  #pills-estafeta-tab.active { background-color: #198754; } 
</style>

<body class="bg-light">

  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-12 col-sm-10 col-md-8 col-lg-6">

        <div class="text-center mb-4">
          <h3 class="fw-bold">Marketplace Local</h3>
          <p class="text-muted">Crie a sua conta</p>
        </div>

        <div class="card border-0 shadow-sm">
          <div class="card-body p-4 p-md-5">

            <% if (locals.erro) { %>
              <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle me-2"></i> <%= locals.erro %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
              </div>
            <% } %>

            <ul class="nav nav-pills nav-justified mb-4" id="pills-tab" role="tablist">
              <li class="nav-item" role="presentation">
                <button class="nav-link active fw-semibold" id="pills-supermercado-tab" data-bs-toggle="pill" data-bs-target="#pills-supermercado" type="button" role="tab">Supermercado</button>
              </li>
              <li class="nav-item" role="presentation">
                <button class="nav-link fw-semibold" id="pills-estafeta-tab" data-bs-toggle="pill" data-bs-target="#pills-estafeta" type="button" role="tab">Estafeta</button>
              </li>
            </ul>

            <div class="tab-content" id="pills-tabContent">
              
              <div class="tab-pane fade show active" id="pills-supermercado" role="tabpanel">
                
                <form action="/auth/register/supermarket" method="POST">
                  
                  <div class="row">
                    <div class="col-md-6 mb-3">
                      <label for="nomeSuper" class="form-label">Nome do Supermercado</label>
                      <input type="text" class="form-control" id="nomeSuper" name="nome" required>
                    </div>
                    <div class="col-md-6 mb-3">
                      <label for="telefoneSuper" class="form-label">Telefone</label>
                      <input type="tel" class="form-control" id="telefoneSuper" name="telefone" required>
                    </div>
                  </div>

                  <div class="mb-3">
                    <label for="moradaSuper" class="form-label">Morada / Localização</label>
                    <input type="text" class="form-control" id="moradaSuper" name="morada" required>
                  </div>

                  <div class="row">
                    <div class="col-md-6 mb-3">
                      <label class="form-label small fw-bold">Password</label>
                      <input type="password" class="form-control" id="passwordSuper" name="password" required>
                    </div>
                    <div class="col-md-6 mb-4">
                      <label class="form-label small fw-bold">Confirmar Password</label>
                      <input type="password" class="form-control" id="confirmPasswordSuper" required>
                    </div>
                  </div>

                  <button type="submit" class="btn btn-primary w-100">Registar Supermercado</button>
                </form>
              </div>

              <div class="tab-pane fade" id="pills-estafeta" role="tabpanel">
                
                <form action="/auth/registo/estafeta" method="POST">
                  
                  <div class="row">
                    <div class="col-md-6 mb-3">
                      <label for="nomeEstafeta" class="form-label">Nome Completo</label>
                      <input type="text" class="form-control" id="nomeEstafeta" name="nome" required>
                    </div>
                    <div class="col-md-6 mb-3">
                      <label for="telefoneEstafeta" class="form-label">Telemóvel</label>
                      <input type="tel" class="form-control" id="telefoneEstafeta" name="telefone" required>
                    </div>
                  </div>

                  <div class="mb-3">
                    <label for="moradaEstafeta" class="form-label">Morada / Zona de Atuação</label>
                    <input type="text" class="form-control" id="moradaEstafeta" name="morada" required>
                  </div>

                  <div class="row">
                    <div class="col-md-6 mb-3">
                      <label class="form-label small fw-bold">Password</label>
                      <input type="password" class="form-control" id="passwordEstafeta" name="password" required>
                    </div>
                    <div class="col-md-6 mb-4">
                      <label class="form-label small fw-bold">Confirmar Password</label>
                      <input type="password" class="form-control" id="confirmPasswordEstafeta" required>
                    </div>
                  </div>

                  <button type="submit" class="btn btn-success w-100">Registar Estafeta</button>
                </form>
              </div>

            </div> <hr class="my-4">

            <p class="text-center text-muted mb-0" style="font-size: 14px">
              Já tem uma conta aprovada? 
              <a href="/auth/login" class="text-decoration-none">Entrar aqui</a>
            </p>

          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    function validarSenhas(idSenha, idConfirma) {
      const senha = document.getElementById(idSenha);
      const confirma = document.getElementById(idConfirma);

      if (senha.value !== confirma.value) {
        alert("Erro: As passwords não coincidem. Por favor, verifique.");
        confirma.style.borderColor = "#dc3545";
        confirma.focus();
        return false; // Bloqueia o envio do formulário
      }
      return true; // Permite o envio
    }

    // Aplicar ao formulário do Supermercado
    document.getElementById('formSuper').onsubmit = function() {
      return validarSenhas('passwordSuper', 'confirmPasswordSuper');
    };

    // Aplicar ao formulário do Estafeta
    document.getElementById('formEstafeta').onsubmit = function() {
      return validarSenhas('passwordEstafeta', 'confirmPasswordEstafeta');
    };
  </script>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
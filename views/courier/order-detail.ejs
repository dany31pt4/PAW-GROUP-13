<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Encomenda #<%= order._id %> — Estafeta</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/style/admin.css">
</head>
<body>

    <%- include('../partials/sidebar-courier', { activePage: activePage, availableCount: 0 }) %>

    <main class="main-wrapper">

        <div class="d-flex align-items-center mb-4 gap-3">
            <a href="<%= backUrl %>" class="btn btn-light border shadow-sm" style="border-radius: 10px;">
                <i class="bi bi-arrow-left me-1"></i> Voltar
            </a>
            <div>
                <h4 class="fw-bold mb-0">Detalhes da Encomenda</h4>
                <p class="text-muted small mb-0 font-monospace">#<%= order._id %></p>
            </div>
        </div>

        <%
            const statusMap = {
                pending:          { badge: 'bg-warning-subtle text-warning border-warning-subtle',           label: 'Pendente' },
                confirmed:        { badge: 'bg-info-subtle text-info border-info-subtle',                     label: 'Confirmada' },
                preparing:        { badge: 'bg-primary-subtle text-primary border-primary-subtle',           label: 'Em Preparação' },
                awaiting_courier: { badge: 'bg-warning-subtle text-warning border-warning-subtle',           label: 'Aguarda Estafeta' },
                delivering:       { badge: 'bg-secondary-subtle text-secondary border-secondary-subtle',     label: 'Com Estafeta' },
                delivered:        { badge: 'bg-success-subtle text-success border-success-subtle',           label: 'Entregue' },
                cancelled:        { badge: 'bg-danger-subtle text-danger border-danger-subtle',              label: 'Cancelada' },
            };
            const current = statusMap[order.status] || { badge: 'bg-light text-dark', label: order.status };
        %>

        <div class="row g-4">

            <!-- Coluna esquerda: resumo -->
            <div class="col-lg-4">
                <div class="table-card mt-0">

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h6 class="fw-semibold mb-0">Resumo</h6>
                        <span class="badge border <%= current.badge %> px-3 py-2"><%= current.label %></span>
                    </div>

                    <div class="mb-3">
                        <div class="text-muted small mb-1"><i class="bi bi-person me-1"></i>Cliente</div>
                        <div class="fw-semibold"><%= order.customer ? order.customer.name : 'N/A' %></div>
                        <% if (order.customer && order.customer.email) { %>
                            <div class="text-muted small"><%= order.customer.email %></div>
                        <% } %>
                    </div>

                    <div class="mb-3">
                        <div class="text-muted small mb-1"><i class="bi bi-shop me-1"></i>Supermercado</div>
                        <div class="fw-semibold"><%= order.supermarket ? order.supermarket.name : 'N/A' %></div>
                    </div>

                    <div class="mb-3">
                        <div class="text-muted small mb-1"><i class="bi bi-calendar3 me-1"></i>Data</div>
                        <div class="fw-semibold">
                            <%= new Date(order.createdAt).toLocaleDateString('pt-PT', { day: '2-digit', month: 'long', year: 'numeric' }) %>
                        </div>
                        <div class="text-muted small">
                            <%= new Date(order.createdAt).toLocaleTimeString('pt-PT', { hour: '2-digit', minute: '2-digit' }) %>
                        </div>
                    </div>

                    <hr>

                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted small">Subtotal</span>
                        <span class="fw-semibold"><%= order.total.toFixed(2) %> €</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted small">Entrega</span>
                        <span class="fw-semibold"><%= order.deliveryCost.toFixed(2) %> €</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="fw-bold">Total</span>
                        <span class="fw-bold fs-5"><%= (order.total + order.deliveryCost).toFixed(2) %> €</span>
                    </div>

                    <% if (order.status === 'awaiting_courier') { %>
                        <div class="mt-4">
                            <button class="btn btn-primary w-100" onclick="acceptDelivery('<%= order._id %>')">
                                <i class="bi bi-check-lg me-1"></i> Aceitar Entrega
                            </button>
                        </div>
                    <% } else if (order.status === 'delivering') { %>
                        <div class="mt-4">
                            <button class="btn btn-success w-100" onclick="completeDelivery('<%= order._id %>')">
                                <i class="bi bi-check-lg me-1"></i> Marcar como Entregue
                            </button>
                        </div>
                    <% } %>

                </div>
            </div>

            <!-- Coluna direita: produtos -->
            <div class="col-lg-8">
                <div class="table-card mt-0">
                    <h6 class="fw-semibold mb-4">Produtos da Encomenda</h6>
                    <div class="table-responsive">
                        <table class="table align-middle mb-0" style="font-size:14px">
                            <thead class="table-light text-secondary" style="font-size:12px">
                                <tr>
                                    <th>Produto</th>
                                    <th class="text-center">Qtd.</th>
                                    <th class="text-end">Preço unit.</th>
                                    <th class="text-end">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% order.products.forEach(function(item) { %>
                                <tr>
                                    <td>
                                        <% if (item.product && item.product.image) { %>
                                            <img src="<%= item.product.image %>" class="rounded-2 me-2" style="width:32px; height:32px; object-fit:cover;">
                                        <% } %>
                                        <strong><%= item.product ? item.product.name : 'Produto indisponível' %></strong>
                                    </td>
                                    <td class="text-center"><%= item.quantity %></td>
                                    <td class="text-end"><%= item.unitPrice.toFixed(2) %> €</td>
                                    <td class="text-end fw-bold"><%= (item.unitPrice * item.quantity).toFixed(2) %> €</td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>

    </main>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/scripts/courier.js"></script>
</body>
</html>
